# ── Server ───────────────────────────────────────────────────
PORT=8080
ENV=development

# ── Database ─────────────────────────────────────────────────
DB_URL=postgres://quran:quran_secret@localhost:5432/quran_school?sslmode=disable

# ── Migrations ───────────────────────────────────────────────
MIGRATIONS_DIR=./migrations
# Set to "true" only when you want startup to auto-apply pending migrations.
# Default is "false" — run manually: make migrate
RUN_MIGRATIONS=false

# ── JWT ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_use_openssl_rand_hex_32_for_production
JWT_REFRESH_SECRET=change_me_different_secret_for_refresh_tokens
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
