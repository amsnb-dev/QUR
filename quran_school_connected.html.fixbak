async function loadTeachers() {
  const teachers = LC.get('teachers');
  const q = (document.getElementById('teacherSearch')?.value||'').toLowerCase();
  const filtered = q ? teachers.filter(t=>t.name.toLowerCase().includes(q)) : teachers;
  const grid = document.getElementById('teachersGrid');
  if (!filtered.length) {
    grid.innerHTML='<div class="empty" style="grid-column:1/-1"><div class="empty-icon">👨‍🏫</div><h4>لا يوجد معلمون</h4><p>قم بإضافة معلم جديد</p></div>';
    return;
  }
  grid.innerHTML = filtered.map(t=>`
    <div class="card" style="margin-bottom:0">
      <div style="padding:20px;text-align:center">
        <div class="av av-green" style="width:64px;height:64px;font-size:28px;margin:0 auto 12px;box-shadow:0 6px 18px rgba(13,92,58,.2)">👨</div>
        <div style="font-size:16px;font-weight:800;margin-bottom:4px">${t.name}</div>
        <div style="font-size:12px;color:var(--text3);margin-bottom:8px">${SPEC_LABELS[t.spec]||t.spec||'-'}</div>
        <div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap">${statusBadge(t.status)}<span class="badge bb">${t.exp||0} سنوات خبرة</span></div>
      </div>
      <div style="padding:0 18px 14px">
        <div class="info-row">
          <div class="info-item"><div class="lbl">الجوال</div><div class="val" dir="ltr" style="font-size:12px">${t.phone||'-'}</div></div>
          <div class="info-item"><div class="lbl">الراتب</div><div class="val" style="color:var(--g2)">${t.baseSalary||0} ريال</div></div>
        </div>
        <div class="info-item" style="margin-top:6px"><div class="lbl">المؤهل</div><div class="val" style="font-size:12px">${t.qual||'-'}</div></div>
      </div>
      <div style="border-top:1px solid var(--border);padding:12px 16px;display:flex;gap:8px">
        <button class="btn btn-outline btn-sm" style="flex:1" onclick="editTeacher(${t.id})">✏️ تعديل</button>
        <button class="btn btn-primary btn-sm" style="flex:1" onclick="viewPayslipTeacher(${t.id})">💰 راتب</button>
        <button class="btn btn-danger btn-sm" onclick="deleteItem('teachers',${t.id},'المعلم')">🗑️</button>
      </div>
    </div>
  `).join('');
}

function filterTeachers() { loadTeachers(); }

async function editTeacher(id) {
  const t = LC.get('teachers').find(x=>x.id===id);
  if (!t) return;
  document.getElementById('editTeacherId').value = t.id;
  document.getElementById('tcName').value = t.name||'';
  document.getElementById('tcPhone').value = t.phone||'';
  document.getElementById('tcId').value = t.idNum||'';
  document.getElementById('tcSpec').value = t.spec||'hafz';
  document.getElementById('tcQual').value = t.qual||'';
  document.getElementById('tcExp').value = t.exp||0;
  document.getElementById('tcBaseSalary').value = t.baseSalary||0;
  document.getElementById('tcHousing').value = t.housing||0;
  document.getElementById('tcTransport').value = t.transport||0;
  document.getElementById('tcHireDate').value = t.hireDate||'';
  document.getElementById('tcIban').value = t.iban||'';
  openModal('addTeacherModal');
}

async function saveTeacher() {
  const id = document.getElementById('editTeacherId').value;
  const name = document.getElementById('tcName').value.trim();
  if (!name) { toast('الاسم مطلوب','error'); return; }
  const data = {
    name, phone:document.getElementById('tcPhone').value,
    idNum:document.getElementById('tcId').value,
    spec:document.getElementById('tcSpec').value,
    qual:document.getElementById('tcQual').value,
    exp:Number(document.getElementById('tcExp').value)||0,
    baseSalary:Number(document.getElementById('tcBaseSalary').value)||0,
    housing:Number(document.getElementById('tcHousing').value)||0,
    transport:Number(document.getElementById('tcTransport').value)||0,
    hireDate:document.getElementById('tcHireDate').value,
    iban:document.getElementById('tcIban').value,
    status:'active'
  };
  if (id) { LC.put('teachers', {...data, id:Number(id)}); toast('✅ تم تحديث بيانات المعلم'); }
  else { LC.add('teachers', data); toast('✅ تم إضافة المعلم'); }
  closeModal('addTeacherModal');
  document.getElementById('editTeacherId').value='';
  loadTeachers();
}

// ==================== GROUPS ====================
async function loadGroups() {
  const groups = await apiGetGroups();
  const students = await apiGetStudents();
  const teachers = LC.get('teachers');
  const tMap={};teachers.forEach(t=>tMap[t.id]=t.name);
  const grid = document.getElementById('groupsGrid');
  const DAYS_SHORT = ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس'];
  if (!groups.length) {
    grid.innerHTML='<div class="empty" style="grid-column:1/-1"><div class="empty-icon">👥</div><h4>لا توجد حلقات</h4></div>';
    return;
  }
  // Count students per group
  const groupCounts = {};
  for (const s of students) {
    const sgs = await apiGetStudentGroups(s.id);
    sgs.forEach(sg => { if(sg.is_active!==false) groupCounts[sg.group_id]=(groupCounts[sg.group_id]||0)+1; });
  }
  grid.innerHTML = groups.map(g=>{
    const count = groupCounts[g.id]||0;
    const days = (g.days||[]).map(d=>DAYS_SHORT[d]||'').join('، ');
    const pct = g.capacity ? Math.round(count/g.capacity*100):0;
    return `
      <div class="card" style="margin-bottom:0">
        <div class="card-head">
          <span class="card-title">${g.name}</span>
          <span class="badge ${pct>90?'br':pct>70?'by':'bg'}">${count}/${g.capacity||'∞'}</span>
        </div>
        <div class="card-body">
          <div class="info-row">
            <div class="info-item"><div class="lbl">القاعة</div><div class="val" style="font-size:12px">${g.room||'-'}</div></div>
            <div class="info-item"><div class="lbl">المستوى</div><div class="val" style="font-size:12px">${LEVEL_LABELS[g.level]||'-'}</div></div>
          </div>
          <div class="info-row">
            <div class="info-item"><div class="lbl">أيام الدراسة</div><div class="val" style="font-size:11px">${days||'-'}</div></div>
            <div class="info-item"><div class="lbl">الوقت</div><div class="val" style="font-size:12px" dir="ltr">${g.startTime||'-'} - ${g.endTime||'-'}</div></div>
          </div>
          <div style="margin-top:8px">
            <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text3);margin-bottom:4px"><span>الاكتظاظ</span><span>${pct}%</span></div>
            <div class="prog-wrap"><div class="prog-fill ${pct>90?'prog-red':pct>70?'prog-gold':'prog-green'}" style="width:${pct}%"></div></div>
          </div>
        </div>
        <div style="padding:12px 16px;border-top:1px solid var(--border);display:flex;gap:8px">
          <button class="btn btn-outline btn-sm" style="flex:1" onclick="editGroup('${g.id}')">✏️ تعديل</button>
          <button class="btn btn-danger btn-sm" onclick="archiveGroup('${g.id}','${g.name.replace(/'/g,"\\'")}')">🗑️</button>
        </div>
      </div>
    `;
  }).join('');
}

async function saveGroup() {
  const id = document.getElementById('editGroupId').value;
  const name = document.getElementById('gpName').value.trim();
  if (!name) { toast('اسم الحلقة مطلوب','error'); return; }
  const days = [...document.querySelectorAll('[name="gpDays"]:checked')].map(c=>Number(c.value));
  const teacherId = document.getElementById('gpTeacher').value;
  const data = {
    name, teacherId,
    days: days.length ? days : [0,1,2,3,4],
    room:document.getElementById('gpRoom').value,
    startTime:document.getElementById('gpStartTime').value,
    endTime:document.getElementById('gpEndTime').value,
    capacity:Number(document.getElementById('gpCapacity').value)||30,
    level:document.getElementById('gpLevel').value
  };
  try {
    await apiSaveGroup(data, id||null);
    if (id) toast('✅ تم تحديث الحلقة');
    else toast('✅ تم إضافة الحلقة');
    closeModal('addGroupModal');
    document.getElementById('editGroupId').value='';
    document.getElementById('gpName').value='';
    loadGroups();
  } catch(e) { toast(e.message||'خطأ','error'); }
}

async function editGroup(id) {
  const groups = await apiGetGroups();
  const g = groups.find(x=>x.id===id);
  if (!g) return;
  document.getElementById('editGroupId').value = g.id;
  document.getElementById('gpName').value = g.name||'';
  document.getElementById('gpRoom').value = g.room||'';
  document.getElementById('gpStartTime').value = g.startTime||'';
  document.getElementById('gpEndTime').value = g.endTime||'';
  document.getElementById('gpCapacity').value = g.capacity||30;
  document.getElementById('gpLevel').value = g.level||'mixed';
  await populateGroupSelect('gpTeacher','teachers');
  document.querySelectorAll('[name="gpDays"]').forEach(c=>c.checked=(g.days||[]).includes(Number(c.value)));
  openModal('addGroupModal');
}

async function archiveGroup(id, name) {
  showConfirm('أرشفة حلقة', 'هل تريد أرشفة الحلقة "'+name+'"؟', async()=>{
    try {
      await apiPatch('/groups/'+id+'/archive');
      toast('🗂️ تم أرشفة الحلقة','warning');
      loadGroups();
    } catch(e) { toast(e.message||'خطأ','error'); }
  });
}

// ==================== SCHEDULE ====================
async function loadSchedule() {
  const schedule = LC.get('schedule');
  const groups = await apiGetGroups();
  const gMap={};groups.forEach(g=>gMap[g.id]=g.name);
  const DAYS_FULL = ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس'];
  const colors = ['var(--g2)','var(--gold2)','var(--blue2)','var(--g3)','#8e44ad'];
  let html = '';
  DAYS_FULL.forEach((day,i)=>{
    const dayItems = schedule.filter(s=>Number(s.day)===i).sort((a,b)=>a.startTime?.localeCompare(b.startTime));
    html += `<div style="margin-bottom:18px">
      <div style="font-size:14px;font-weight:800;color:var(--g1);margin-bottom:10px;display:flex;align-items:center;gap:10px">
        ${day}<div style="flex:1;height:1px;background:var(--border)"></div>
      </div>`;
    if (!dayItems.length) { html+='<div style="color:var(--text3);font-size:12px;padding:8px 0">لا يوجد جدول</div>'; }
    else dayItems.forEach((s,j)=>{
      html+=`<div style="display:flex;gap:14px;padding:12px 16px;background:var(--cream);border-radius:10px;border-right:4px solid ${colors[j%5]};margin-bottom:8px;align-items:center">
        <span style="font-size:12px;font-weight:700;color:var(--g2);min-width:70px" dir="ltr">${s.startTime||'-'} - ${s.endTime||'-'}</span>
        <div style="flex:1"><div style="font-size:13px;font-weight:700">${gMap[s.groupId]||s.activityName||'-'}</div><div style="font-size:11px;color:var(--text3);margin-top:2px">${s.room?'📍 '+s.room:''}</div></div>
        <span class="badge ${s.type==='exam'?'br':s.type==='review'?'by':'bg'}">${{regular:'حلقة',review:'مراجعة',exam:'اختبار',event:'نشاط'}[s.type]||s.type}</span>
        <button class="btn btn-xs btn-danger" onclick="deleteItem('schedule',${s.id},'الموعد')">🗑️</button>
      </div>`;
    });
    html += '</div>';
  });
  document.getElementById('scheduleBoard').innerHTML = html;
  await populateGroupSelect('schGroup');
}

async function saveSchedule() {
  LC.add('schedule', {
    groupId:document.getElementById('schGroup').value,
    day:Number(document.getElementById('schDay').value),
    startTime:document.getElementById('schStart').value,
    endTime:document.getElementById('schEnd').value,
    room:document.getElementById('schRoom').value,
    type:document.getElementById('schType').value
  });
  toast('✅ تم إضافة الموعد');
  closeModal('addScheduleModal');
  loadSchedule();
}

// ==================== FEES ====================
async function loadFees() {
  const students = await apiGetStudents();
  const fees = LC.get('fees');
  const settings = LC.get('settings');
  const monthly = Number(settings.find?settings.find(s=>s.key==='monthlyFee')?.value:500)||500;
  const totalCollected = fees.reduce((a,f)=>a+Number(f.amount||0),0);
  const activeStudents = students.filter(s=>s.status==='active'&&s.feeStatus!=='full');
  const expectedMonthly = activeStudents.reduce((a,s)=>a+Number(s.feeAmount||monthly),0);
  const thisMonthFees = fees.filter(f=>f.month===thisMonth());
  const collectedThisMonth = thisMonthFees.reduce((a,f)=>a+Number(f.amount||0),0);
  const overdueStudents = activeStudents.filter(s=>!fees.some(f=>f.studentId===s.id&&f.month===thisMonth()));

  document.getElementById('feeStats').innerHTML = `
    <div class="stat-card green"><div class="stat-icon-wrap si-green">💰</div><div class="stat-body"><div class="stat-val">${totalCollected.toLocaleString()}</div><div class="stat-lbl">إجمالي المحصّل (ريال)</div></div></div>
    <div class="stat-card blue"><div class="stat-icon-wrap si-blue">📅</div><div class="stat-body"><div class="stat-val">${collectedThisMonth.toLocaleString()}</div><div class="stat-lbl">محصّل هذا الشهر</div></div></div>
    <div class="stat-card red"><div class="stat-icon-wrap si-red">⚠️</div><div class="stat-body"><div class="stat-val">${overdueStudents.length}</div><div class="stat-lbl">طالب لم يسدد</div></div></div>
    <div class="stat-card gold"><div class="stat-icon-wrap si-gold">📊</div><div class="stat-body"><div class="stat-val">${expectedMonthly>0?Math.round(collectedThisMonth/expectedMonthly*100):0}%</div><div class="stat-lbl">نسبة التحصيل</div></div></div>
  `;

  const sMap={};students.forEach(s=>sMap[s.id]=s.name);
  const feeStudent = document.getElementById('feeStudent');
  feeStudent.innerHTML = students.map(s=>`<option value="${s.id}">${s.name}</option>`).join('');
  document.getElementById('feeMonth').value = thisMonth();
  document.getElementById('feeDate').value = today();

  // Payments table
  const sorted = [...fees].sort((a,b)=>b.createdAt-a.createdAt).slice(0,30);
  document.querySelector('#feesTable tbody').innerHTML = sorted.map(f=>`
    <tr><td class="td-name">${sMap[f.studentId]||'-'}</td>
    <td><strong style="color:#16a34a">${Number(f.amount).toLocaleString()} ريال</strong></td>
    <td>${f.month||'-'}</td><td>${FEE_METHODS[f.method]||f.method}</td><td>${f.date||'-'}</td>
    <td><button class="btn btn-xs btn-outline" onclick="printReceipt(${f.id})">🧾</button></td></tr>
  `).join('') || '<tr><td colspan="6"><div class="empty"><p>لا توجد مدفوعات</p></div></td></tr>';

  // Overdue
  document.getElementById('overdueCount').textContent = overdueStudents.length;
  document.querySelector('#overdueTable tbody').innerHTML = overdueStudents.slice(0,20).map(s=>`
    <tr><td class="td-name">${s.name}</td>
    <td><span class="badge br">هذا الشهر</span></td>
    <td><strong style="color:var(--red2)">${formatMoney(s.feeAmount)}</strong></td>
    <td dir="ltr">${s.phone||'-'}</td>
    <td><button class="btn btn-xs btn-primary" onclick="quickPayFee('${s.id}')">💳 سداد</button></td></tr>
  `).join('') || '<tr><td colspan="5"><div class="empty"><p>جميع الطلاب سددوا رسومهم 🎉</p></div></td></tr>';
}

async function saveFeePayment() {
  const studentId = document.getElementById('feeStudent').value;
  const amount = Number(document.getElementById('feeAmount').value);
  if (!studentId) { toast('اختر الطالب','error'); return; }
  if (!amount||amount<=0) { toast('أدخل المبلغ','error'); return; }
  LC.add('fees', {
    studentId, amount, method:document.getElementById('feeMethod').value,
    month:document.getElementById('feeMonth').value, date:document.getElementById('feeDate').value,
    note:document.getElementById('feeNote').value
  });
  toast('✅ تم تسجيل الدفعة');
  document.getElementById('feeAmount').value='';
  document.getElementById('feeNote').value='';
  loadFees();
}

async function quickPayFee(studentId) {
  const s = _studentsCache.find(x=>x.id===studentId);
  if (!s) return;
  document.getElementById('feeStudent').value = studentId;
  document.getElementById('feeAmount').value = s.feeAmount||500;
  document.getElementById('feeMonth').value = thisMonth();
  document.getElementById('feeDate').value = today();
  toast('تم تعبئة بيانات الطالب — راجع واضغط تسجيل');
}

async function printReceipt(id) {
  const f = LC.get('fees').find(x=>x.id===id);
  if (!f) return;
  const students = await apiGetStudents();
  const sMap={};students.forEach(s=>sMap[s.id]=s.name);
  const schoolName = LC.get('settings').find?LC.get('settings').find(s=>s.key==='schoolName')?.value||'نور القرآن':'نور القرآن';
  const w = window.open('','_blank');
  w.document.write('<html dir="rtl"><head><meta charset="UTF-8"><style>body{font-family:Arial;max-width:400px;margin:40px auto;padding:20px;border:2px solid #333}h2{text-align:center;color:#0d5c3a}.row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #eee}.total{font-size:20px;font-weight:bold;color:#0d5c3a}</style></head><body>'
    +'<h2>🌙 '+schoolName+'</h2>'
    +'<p style="text-align:center;color:#888">إيصال رسوم دراسية</p>'
    +'<div class="row"><span>اسم الطالب</span><span>'+(sMap[f.studentId]||'-')+'</span></div>'
    +'<div class="row"><span>المبلغ</span><span class="total">'+Number(f.amount).toLocaleString()+' ريال</span></div>'
    +'<div class="row"><span>الشهر</span><span>'+(f.month||'-')+'</span></div>'
    +'<div class="row"><span>طريقة الدفع</span><span>'+(FEE_METHODS[f.method]||'-')+'</span></div>'
    +'<div class="row"><span>التاريخ</span><span>'+(f.date||today())+'</span></div>'
    +'<p style="text-align:center;margin-top:20px;color:#888;font-size:12px">شكراً لتعاونكم</p>'
    +'<scr'+'ipt>window.print();window.close();</scr'+'ipt></body></html>');
}

// ==================== PAYROLL ====================
async function loadPayroll() {
  const teachers = LC.get('teachers');
  const payroll = LC.get('payroll');
  const activeTeachers = teachers.filter(t=>(t.status||'active')==='active');
  const thisMonthPayroll = payroll.filter(p=>p.month===thisMonth());
  const totalSalaries = thisMonthPayroll.reduce((a,p)=>a+Number(p.net||0),0);
  const totalBase = activeTeachers.reduce((a,t)=>a+Number(t.baseSalary||0),0);
  const pending = activeTeachers.filter(t=>!thisMonthPayroll.some(p=>p.teacherId===t.id)).length;

  document.getElementById('payrollStats').innerHTML = `
    <div class="stat-card green"><div class="stat-icon-wrap si-green">💸</div><div class="stat-body"><div class="stat-val">${totalSalaries.toLocaleString()}</div><div class="stat-lbl">صُرف هذا الشهر (ريال)</div></div></div>
    <div class="stat-card gold"><div class="stat-icon-wrap si-gold">📋</div><div class="stat-body"><div class="stat-val">${totalBase.toLocaleString()}</div><div class="stat-lbl">إجمالي الرواتب الأساسية</div></div></div>
    <div class="stat-card red"><div class="stat-icon-wrap si-red">⏳</div><div class="stat-body"><div class="stat-val">${pending}</div><div class="stat-lbl">موظف لم يُصرف راتبه</div></div></div>
  `;
  document.getElementById('payrollMonth').value = thisMonth();
  document.getElementById('payrollDate').value = today();
  const pMap={};thisMonthPayroll.forEach(p=>pMap[p.teacherId]=p);
  document.getElementById('payrollTeachersList').innerHTML = activeTeachers.map(t=>{
    const existing=pMap[t.id];
    const total=Number(t.baseSalary||0)+Number(t.housing||0)+Number(t.transport||0);
    return `<div style="display:flex;align-items:center;gap:12px;padding:12px;background:${existing?'#d1fae5':'var(--cream)'};border-radius:10px;margin-bottom:8px;border:1px solid ${existing?'#a7f3d0':'var(--border)'}">
      <div class="av av-green">👨</div>
      <div style="flex:1"><div style="font-size:13px;font-weight:700">${t.name}</div><div style="font-size:11px;color:var(--text3)">${SPEC_LABELS[t.spec]||'-'} • أساسي: ${Number(t.baseSalary||0).toLocaleString()} ريال</div></div>
      <div style="text-align:left"><div style="font-size:15px;font-weight:800;color:var(--g2)">${total.toLocaleString()} ريال</div>${existing?'<span class="badge bg" style="font-size:9px">صُرف ✓</span>':'<span class="badge by" style="font-size:9px">معلق</span>'}</div>
    </div>`;
  }).join('')||'<div class="empty"><p>لا يوجد معلمون — أضفهم من صفحة المعلمون</p></div>';
  let total=0,totalAll=0;
  activeTeachers.forEach(t=>{total+=Number(t.baseSalary||0);totalAll+=Number(t.housing||0)+Number(t.transport||0);});
  document.getElementById('totalSalary').textContent=total.toLocaleString();
  document.getElementById('totalAllowances').textContent=totalAll.toLocaleString();
  document.getElementById('totalDeductions').textContent='0';
  const sel=document.getElementById('salaryTeacher');
  sel.innerHTML=activeTeachers.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  if(activeTeachers.length) loadTeacherSalary();
  const tMap={};teachers.forEach(t=>tMap[t.id]=t.name);
  const sorted=[...payroll].sort((a,b)=>b.createdAt-a.createdAt).slice(0,30);
  document.querySelector('#payrollTable tbody').innerHTML=sorted.map(p=>`
    <tr><td class="td-name">${tMap[p.teacherId]||'-'}</td><td>${p.month||'-'}</td>
    <td>${Number(p.base||0).toLocaleString()}</td><td style="color:#16a34a">+${Number(p.allowances||0).toLocaleString()}</td>
    <td style="color:var(--red2)">-${Number(p.deductions||0).toLocaleString()}</td>
    <td><strong style="color:var(--g2)">${Number(p.net||0).toLocaleString()} ريال</strong></td>
    <td>${p.date||'-'}</td>
    <td><button class="btn btn-xs btn-outline" onclick="showPayslip(${p.id})">🧾</button>
    <button class="btn btn-xs btn-danger" onclick="deleteItem('payroll',${p.id},'سجل الراتب')">🗑️</button></td></tr>
  `).join('')||'<tr><td colspan="8"><div class="empty"><p>لا يوجد سجل رواتب</p></div></td></tr>';
}

async function loadTeacherSalary() {
  const id = Number(document.getElementById('salaryTeacher').value);
  if (!id) return;
  const t = LC.get('teachers').find(x=>x.id===id);
  if (!t) return;
  const total=Number(t.baseSalary||0)+Number(t.housing||0)+Number(t.transport||0);
  document.getElementById('teacherSalaryForm').innerHTML = `
    <div class="salary-card"><h3>الراتب الحالي لـ ${t.name}</h3><div class="amount">${total.toLocaleString()} <span style="font-size:16px">ريال</span></div><div class="sub">الشهر الحالي</div></div>
    <div class="form-row fr-2" style="margin-bottom:12px">
      <div class="form-group"><label class="form-label">الراتب الأساسي</label><input type="number" class="form-control" id="sc-base" value="${t.baseSalary||0}"></div>
      <div class="form-group"><label class="form-label">بدل السكن</label><input type="number" class="form-control" id="sc-housing" value="${t.housing||0}"></div>
    </div>
    <div class="form-row fr-2" style="margin-bottom:14px">
      <div class="form-group"><label class="form-label">بدل النقل</label><input type="number" class="form-control" id="sc-transport" value="${t.transport||0}"></div>
      <div class="form-group"><label class="form-label">مكافأة إضافية</label><input type="number" class="form-control" id="sc-bonus" value="0"></div>
    </div>
    <button class="btn btn-primary btn-block" onclick="updateTeacherSalary(${t.id})">💾 تحديث الراتب</button>
  `;
}

async function updateTeacherSalary(id) {
  const teachers = LC.get('teachers');
  const t = teachers.find(x=>x.id===id);
  if (!t) return;
  LC.put('teachers', {...t, baseSalary:Number(document.getElementById('sc-base').value)||0, housing:Number(document.getElementById('sc-housing').value)||0, transport:Number(document.getElementById('sc-transport').value)||0});
  toast('✅ تم تحديث بيانات الراتب');
  loadPayroll();
}

async function runPayroll() {
  const month=document.getElementById('payrollMonth').value;
  const date=document.getElementById('payrollDate').value;
  const teachers=LC.get('teachers');
  const existing=LC.get('payroll');
  const activeT=teachers.filter(t=>(t.status||'active')==='active');
  const settings=LC.get('settings');
  const gosiRate=Number(Array.isArray(settings)?settings.find(s=>s.key==='gosiRate')?.value:10)||10;
  let count=0;
  for(const t of activeT){
    if(existing.some(p=>p.teacherId===t.id&&p.month===month)) continue;
    const base=Number(t.baseSalary||0),allowances=Number(t.housing||0)+Number(t.transport||0),gosi=Math.round(base*gosiRate/100);
    LC.add('payroll',{teacherId:t.id,teacherName:t.name,month,date,base,allowances,deductions:gosi,gosi,net:base+allowances-gosi,status:'paid',iban:t.iban||''});
    count++;
  }
  if(count===0){toast('تم صرف رواتب هذا الشهر مسبقاً','warning');}
  else{toast(`✅ تم صرف رواتب ${count} موظف بنجاح`);addNotification('💰','صرف الرواتب',`تم صرف رواتب ${count} موظف لشهر ${month}`);}
  loadPayroll();
}

async function showPayslip(id) {
  const p=LC.get('payroll').find(x=>x.id===id);
  if(!p) return;
  const teachers=LC.get('teachers');
  const tMap={};teachers.forEach(t=>tMap[t.id]=t.name);
  const schoolName=Array.isArray(LC.get('settings'))?LC.get('settings').find(s=>s.key==='schoolName')?.value||'نور القرآن':'نور القرآن';
  document.getElementById('payslipContent').innerHTML = `
    <div style="background:linear-gradient(135deg,var(--g1),var(--g2));padding:20px;border-radius:12px;color:#fff;margin-bottom:18px;text-align:center">
      <div style="font-size:20px;margin-bottom:4px">🌙 ${schoolName}</div>
      <div style="font-size:13px;opacity:.7">كشف راتب - ${p.month||'-'}</div>
    </div>
    <div class="info-row" style="margin-bottom:14px">
      <div class="info-item"><div class="lbl">اسم الموظف</div><div class="val">${p.teacherName||tMap[p.teacherId]||'-'}</div></div>
      <div class="info-item"><div class="lbl">تاريخ الصرف</div><div class="val">${p.date||'-'}</div></div>
    </div>
    <table style="width:100%;border-collapse:collapse;margin-bottom:16px">
      <tr style="background:#f0f7f3"><td style="padding:10px;font-weight:700;border-bottom:1px solid var(--border)">البيان</td><td style="padding:10px;text-align:left;font-weight:700;border-bottom:1px solid var(--border)">المبلغ (ريال)</td></tr>
      <tr><td style="padding:9px;border-bottom:1px solid var(--border)">الراتب الأساسي</td><td style="padding:9px;text-align:left;border-bottom:1px solid var(--border)">${Number(p.base||0).toLocaleString()}</td></tr>
      <tr><td style="padding:9px;border-bottom:1px solid var(--border)">البدلات</td><td style="padding:9px;text-align:left;color:#16a34a;border-bottom:1px solid var(--border)">+ ${Number(p.allowances||0).toLocaleString()}</td></tr>
      <tr><td style="padding:9px;border-bottom:1px solid var(--border)">اشتراك التأمينات</td><td style="padding:9px;text-align:left;color:var(--red2);border-bottom:1px solid var(--border)">- ${Number(p.gosi||0).toLocaleString()}</td></tr>
      <tr style="background:#f0f7f3"><td style="padding:12px;font-weight:800;font-size:15px">صافي الراتب</td><td style="padding:12px;text-align:left;font-weight:800;font-size:18px;color:var(--g2)">${Number(p.net||0).toLocaleString()} ريال</td></tr>
    </table>
  `;
  openModal('payslipModal');
}

function viewPayslipTeacher(teacherId) {
  const payrolls=LC.get('payroll');
  const latest=payrolls.filter(p=>p.teacherId===teacherId).sort((a,b)=>b.createdAt-a.createdAt)[0];
  if(latest) showPayslip(latest.id);
  else toast('لا يوجد كشف راتب لهذا المعلم','warning');
}

function printPayslip() { window.print(); }

// ==================== EXPENSES ====================
async function loadExpenses() {
  const expenses=LC.get('expenses');
  const total=expenses.reduce((a,e)=>a+Number(e.amount||0),0);
  const thisMonthExp=expenses.filter(e=>e.date&&e.date.startsWith(thisMonth())).reduce((a,e)=>a+Number(e.amount||0),0);
  const byCategory={};
  Object.keys(EXP_CATS).forEach(k=>byCategory[k]=0);
  expenses.forEach(e=>{byCategory[e.category]=(byCategory[e.category]||0)+Number(e.amount||0)});
  document.getElementById('expStats').innerHTML = `
    <div class="stat-card green"><div class="stat-icon-wrap si-green">📊</div><div class="stat-body"><div class="stat-val">${total.toLocaleString()}</div><div class="stat-lbl">إجمالي المصروفات</div></div></div>
    <div class="stat-card gold"><div class="stat-icon-wrap si-gold">📅</div><div class="stat-body"><div class="stat-val">${thisMonthExp.toLocaleString()}</div><div class="stat-lbl">مصروفات هذا الشهر</div></div></div>
    <div class="stat-card blue"><div class="stat-icon-wrap si-blue">📋</div><div class="stat-body"><div class="stat-val">${expenses.length}</div><div class="stat-lbl">عدد السجلات</div></div></div>
  `;
  document.getElementById('expDate').value=today();
  const maxVal=Math.max(...Object.values(byCategory),1);
  document.getElementById('expChart').innerHTML=`<div class="bar-chart" style="height:140px">${Object.entries(byCategory).map(([k,v])=>`<div class="bar-item" style="position:relative"><span style="font-size:10px;font-weight:700;color:var(--gold2);position:absolute;top:-16px">${v>0?v.toLocaleString():''}</span><div class="bar prog-gold" style="height:${(v/maxVal)*120}px"></div><span style="font-size:9px;color:var(--text3);margin-top:4px;text-align:center">${EXP_CATS[k].slice(0,4)}</span></div>`).join('')}</div>`;
  const sorted=[...expenses].sort((a,b)=>b.createdAt-a.createdAt).slice(0,30);
  document.querySelector('#expensesTable tbody').innerHTML=sorted.map(e=>`
    <tr><td><span class="badge bb">${EXP_CATS[e.category]||e.category}</span></td>
    <td><strong style="color:var(--red2)">${Number(e.amount).toLocaleString()} ريال</strong></td>
    <td>${e.desc||'-'}</td><td>${PAY_METHODS[e.method]||e.method}</td><td>${e.date||'-'}</td>
    <td><button class="btn btn-xs btn-danger" onclick="deleteItem('expenses',${e.id},'المصروف')">🗑️</button></td></tr>
  `).join('')||'<tr><td colspan="6"><div class="empty"><p>لا يوجد مصروفات</p></div></td></tr>';
}

async function saveExpense() {
  const amount=Number(document.getElementById('expAmount').value);
  if(!amount||amount<=0){toast('أدخل المبلغ','error');return;}
  LC.add('expenses',{category:document.getElementById('expCategory').value,amount,method:document.getElementById('expMethod').value,date:document.getElementById('expDate').value||today(),desc:document.getElementById('expDesc').value});
  toast('✅ تم تسجيل المصروف');
  document.getElementById('expAmount').value='';
  document.getElementById('expDesc').value='';
  loadExpenses();
}

// ==================== REPORTS ====================
async function loadReports() {
  const [students, groups] = await Promise.all([apiGetStudents(), apiGetGroups()]);
  const fees=LC.get('fees'),expenses=LC.get('expenses'),payroll=LC.get('payroll');
  const totalFees=fees.reduce((a,f)=>a+Number(f.amount||0),0);
  const totalExp=expenses.reduce((a,e)=>a+Number(e.amount||0),0);
  const totalPayroll=payroll.reduce((a,p)=>a+Number(p.net||0),0);
  const activeS=students.filter(s=>s.status==='active');
  const graduates=students.filter(s=>Number(s.memorized)>=30).length;
  document.getElementById('repStats').innerHTML=`
    <div class="stat-card green"><div class="stat-icon-wrap si-green">🎓</div><div class="stat-body"><div class="stat-val">${activeS.length}</div><div class="stat-lbl">إجمالي الطلاب النشطين</div></div></div>
    <div class="stat-card gold"><div class="stat-icon-wrap si-gold">🏆</div><div class="stat-body"><div class="stat-val">${graduates}</div><div class="stat-lbl">حفّاظ القرآن</div></div></div>
    <div class="stat-card blue"><div class="stat-icon-wrap si-blue">💰</div><div class="stat-body"><div class="stat-val">${totalFees.toLocaleString()}</div><div class="stat-lbl">إجمالي الإيرادات</div></div></div>
    <div class="stat-card red"><div class="stat-icon-wrap si-red">📊</div><div class="stat-body"><div class="stat-val">${(totalFees-totalExp-totalPayroll).toLocaleString()}</div><div class="stat-lbl">الصافي (ريال)</div></div></div>
  `;
  document.getElementById('repGrowthChart').innerHTML='<div class="empty"><p>يتم تحميل بيانات النمو...</p></div>';
  document.getElementById('repFinancialSummary').innerHTML=`
    <div style="display:flex;flex-direction:column;gap:10px">
      <div style="display:flex;justify-content:space-between;padding:10px;background:var(--cream);border-radius:9px"><span>إجمالي الإيرادات</span><span style="font-weight:800;color:#16a34a">${totalFees.toLocaleString()} ريال</span></div>
      <div style="display:flex;justify-content:space-between;padding:10px;background:var(--cream);border-radius:9px"><span>إجمالي الرواتب</span><span style="font-weight:800;color:var(--red2)">${totalPayroll.toLocaleString()} ريال</span></div>
      <div style="display:flex;justify-content:space-between;padding:10px;background:var(--cream);border-radius:9px"><span>إجمالي المصروفات</span><span style="font-weight:800;color:var(--red2)">${totalExp.toLocaleString()} ريال</span></div>
      <div style="display:flex;justify-content:space-between;padding:12px;background:linear-gradient(135deg,#f0f7f3,var(--cream));border-radius:9px;border:1px solid #a7f3d0"><span style="font-size:16px;font-weight:800">الصافي</span><span style="font-size:18px;font-weight:800;color:var(--g2)">${(totalFees-totalExp-totalPayroll).toLocaleString()} ريال</span></div>
    </div>
  `;
  const gMap={};groups.forEach(g=>gMap[g.id]=g.name);
  const repGroup=document.getElementById('repGroup');
  if(repGroup){repGroup.innerHTML='<option value="">كل الحلقات</option>'+groups.map(g=>`<option value="${g.id}">${g.name}</option>`).join('');}
  document.getElementById('repMonth').value=thisMonth();
  document.getElementById('repFinMonth').value=thisMonth();
}

async function generateStudentReport() {
  const gId=document.getElementById('repGroup').value;
  const month=document.getElementById('repMonth').value;
  const [students,groups]=await Promise.all([apiGetStudents(),apiGetGroups()]);
  const gMap={};groups.forEach(g=>gMap[g.id]=g.name);
  let filtered=students;
  const rows=filtered.map(s=>`<tr><td class="td-name">${s.name}</td><td>—</td><td>${s.memorized||0}/30</td><td>—</td><td>—</td><td>${statusBadge(s.status)}</td></tr>`).join('');
  document.getElementById('studentReportContent').innerHTML=`<div class="card"><div class="card-head"><span class="card-title">📊 تقرير الطلاب</span><span class="badge bg">${filtered.length} طالب</span></div><div class="tbl-wrap"><table><thead><tr><th>الطالب</th><th>الحلقة</th><th>المحفوظ</th><th>الحضور</th><th>أيام الغياب</th><th>الحالة</th></tr></thead><tbody>${rows||'<tr><td colspan="6"><div class="empty"><p>لا يوجد بيانات</p></div></td></tr>'}</tbody></table></div></div>`;
}

async function generateFinancialReport() {
  const month=document.getElementById('repFinMonth').value;
  const fees=LC.get('fees'),expenses=LC.get('expenses'),payroll=LC.get('payroll');
  const students=await apiGetStudents();
  const sMap={};students.forEach(s=>sMap[s.id]=s.name);
  const monthFees=month?fees.filter(f=>f.month===month):fees;
  const monthExp=month?expenses.filter(e=>e.date?.startsWith(month)):expenses;
  const monthPay=month?payroll.filter(p=>p.month===month):payroll;
  const totalFees=monthFees.reduce((a,f)=>a+Number(f.amount||0),0);
  const totalExp=monthExp.reduce((a,e)=>a+Number(e.amount||0),0);
  const totalPay=monthPay.reduce((a,p)=>a+Number(p.net||0),0);
  document.getElementById('financialReportContent').innerHTML=`<div class="g2"><div class="card"><div class="card-head"><span class="card-title">💰 الإيرادات</span></div><div class="tbl-wrap"><table><thead><tr><th>الطالب</th><th>المبلغ</th><th>الشهر</th><th>طريقة الدفع</th></tr></thead><tbody>${monthFees.map(f=>`<tr><td>${sMap[f.studentId]||'-'}</td><td style="color:#16a34a;font-weight:700">${Number(f.amount).toLocaleString()} ريال</td><td>${f.month||'-'}</td><td>${FEE_METHODS[f.method]||'-'}</td></tr>`).join('')||'<tr><td colspan="4"><div class="empty"><p>لا توجد إيرادات</p></div></td></tr>'}</tbody></table></div><div style="padding:12px 16px;background:var(--cream2);border-top:1px solid var(--border)"><strong>الإجمالي: ${totalFees.toLocaleString()} ريال</strong></div></div><div class="card"><div class="card-head"><span class="card-title">💸 المصروفات والرواتب</span></div><div class="card-body"><div style="margin-bottom:12px"><div style="font-weight:700;margin-bottom:6px">المصروفات (${totalExp.toLocaleString()} ريال)</div>${monthExp.map(e=>`<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border)"><span>${EXP_CATS[e.category]||e.category} - ${e.desc||''}</span><span style="color:var(--red2)">${Number(e.amount).toLocaleString()}</span></div>`).join('')||'<p style="color:var(--text3);font-size:12px">لا مصروفات</p>'}</div><div><div style="font-weight:700;margin-bottom:6px">الرواتب (${totalPay.toLocaleString()} ريال)</div>${monthPay.map(p=>`<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border)"><span>${p.teacherName||'-'}</span><span style="color:var(--red2)">${Number(p.net||0).toLocaleString()}</span></div>`).join('')||'<p style="color:var(--text3);font-size:12px">لا رواتب</p>'}</div><div style="margin-top:12px;padding:12px;background:var(--cream2);border-radius:9px"><div style="display:flex;justify-content:space-between;font-size:16px;font-weight:800"><span>الصافي</span><span style="color:${totalFees-totalExp-totalPay>=0?'#16a34a':'var(--red2)'}">${(totalFees-totalExp-totalPay).toLocaleString()} ريال</span></div></div></div></div></div>`;
}

// ==================== NOTIFICATIONS ====================
function addNotification(icon, title, text) {
  LC.add('notifications', {icon, title, text, read:false});
  updateNotifBadge();
}

function updateNotifBadge(count) {
  if(count===undefined) count=LC.get('notifications').filter(n=>!n.read).length;
  document.getElementById('notifBadge').textContent=count;
  document.getElementById('notifDot').style.display=count>0?'':'none';
}

async function loadNotifications() {
  const notifications=LC.get('notifications').sort((a,b)=>b.createdAt-a.createdAt);
  const el=document.getElementById('notificationsList');
  if(!notifications.length){el.innerHTML='<div class="empty"><div class="empty-icon">🔔</div><h4>لا توجد إشعارات</h4></div>';return;}
  el.innerHTML=notifications.map(n=>`
    <div style="display:flex;gap:14px;padding:14px;border-radius:12px;background:${n.read?'var(--cream)':'linear-gradient(135deg,#f0fdf4,var(--cream))'};margin-bottom:8px;border:1px solid ${n.read?'var(--border)':'#a7f3d0'}">
      <div style="font-size:24px;line-height:1">${n.icon||'📢'}</div>
      <div style="flex:1"><div style="font-size:13px;font-weight:700;margin-bottom:3px">${n.title||''}</div><div style="font-size:12px;color:var(--text2)">${n.text}</div><div style="font-size:10px;color:var(--text3);margin-top:4px">${formatDate(n.createdAt)}</div></div>
      ${!n.read?`<button class="btn btn-xs btn-outline" onclick="markRead(${n.id})">✓ قراءة</button>`:'<span class="badge bgr" style="font-size:9px">مقروء</span>'}
    </div>
  `).join('');
}

function markRead(id) {
  const all=LC.get('notifications');
  const n=all.find(x=>x.id===id);
  if(n){LC.put('notifications',{...n,read:true});}
  loadNotifications();updateNotifBadge();
}

function markAllRead() {
  const all=LC.get('notifications');
  all.forEach(n=>LC.put('notifications',{...n,read:true}));
  loadNotifications();updateNotifBadge(0);
}

function clearNotifications() {
  showConfirm('مسح الإشعارات','هل تريد مسح جميع الإشعارات؟',()=>{
    LC.clear('notifications');loadNotifications();updateNotifBadge(0);toast('🗑️ تم مسح الإشعارات');
  });
}

// ==================== SETTINGS ====================
async function loadSettings() {
  const settings=LC.get('settings');
  const getS=k=>(Array.isArray(settings)?settings.find(s=>s.key===k)?.value:'')||'';
  document.getElementById('settSchoolName').value=getS('schoolName')||'مدرسة نور القرآن';
  document.getElementById('settAdminName').value=getS('adminName');
  document.getElementById('settPhone').value=getS('phone');
  document.getElementById('settEmail').value=getS('email');
  document.getElementById('settAddress').value=getS('address');
  document.getElementById('settYear').value=getS('year')||'1446-1447 هـ';
  document.getElementById('settCity').value=getS('city');
  document.getElementById('settMonthlyFee').value=getS('monthlyFee')||500;
  document.getElementById('settRegFee').value=getS('regFee')||200;
  document.getElementById('settLateFee').value=getS('lateFee')||50;
  document.getElementById('housingAllowance').value=getS('housingPct')||25;
  document.getElementById('transportAllowance').value=getS('transportPct')||10;
  document.getElementById('absenceDeduction').value=getS('absenceDed')||200;
  document.getElementById('excellenceBonus').value=getS('excellenceBonus')||500;
  document.getElementById('taxRate').value=getS('taxRate')||0;
  document.getElementById('gosiRate').value=getS('gosiRate')||10;
  if(getS('adminName')) document.getElementById('adminName').textContent=getS('adminName');
  const students=await apiGetStudents();
  const teachers=LC.get('teachers');
  document.getElementById('dbStats').innerHTML=`<div class="summary-box"><div><div class="summary-val">${students.length}</div><div class="summary-lbl">طالب</div></div><div><div class="summary-val">${teachers.length}</div><div class="summary-lbl">معلم</div></div><div><div class="summary-val">${LC.get('fees').length+LC.get('attendance_lc').length}</div><div class="summary-lbl">سجل</div></div></div>`;
}

function setSetting(key, value) {
  const all=LC.get('settings')||[];
  const existing=all.find(s=>s.key===key);
  if(existing){LC.put('settings',{...existing,value});}
  else{LC.add('settings',{key,value});}
}

function saveSettings() {
  const fields={schoolName:'settSchoolName',adminName:'settAdminName',phone:'settPhone',email:'settEmail',address:'settAddress',year:'settYear',city:'settCity'};
  for(const[k,id] of Object.entries(fields)) setSetting(k,document.getElementById(id).value);
  toast('✅ تم حفظ إعدادات المدرسة');
  if(document.getElementById('settAdminName').value) document.getElementById('adminName').textContent=document.getElementById('settAdminName').value;
}

function saveFeeSettings() {
  setSetting('monthlyFee',document.getElementById('settMonthlyFee').value);
  setSetting('regFee',document.getElementById('settRegFee').value);
  setSetting('lateFee',document.getElementById('settLateFee').value);
  toast('✅ تم حفظ إعدادات الرسوم');
}

function savePayrollSettings() {
  setSetting('gosiRate',document.getElementById('gosiRate').value);
  setSetting('taxRate',document.getElementById('taxRate').value);
  setSetting('absenceDed',document.getElementById('absenceDeduction').value);
  setSetting('excellenceBonus',document.getElementById('excellenceBonus').value);
  toast('✅ تم حفظ إعدادات الرواتب');
}

async function exportAllData() {
  const students=await apiGetStudents();
  const groups=await apiGetGroups();
  const data={students,groups,fees:LC.get('fees'),payroll:LC.get('payroll'),expenses:LC.get('expenses'),teachers:LC.get('teachers'),notifications:LC.get('notifications')};
  const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`quran_school_backup_${today()}.json`;a.click();
  toast('📤 تم تصدير جميع البيانات');
}

async function resetDatabase() {
  showConfirm('⚠️ إعادة تهيئة النظام','سيتم حذف جميع البيانات المحلية. البيانات في الخادم ستبقى.',()=>{
    ['fees','payroll','expenses','teachers','notifications','settings','recitation','exams','schedule'].forEach(k=>LC.clear(k));
    toast('🗑️ تم مسح البيانات المحلية','warning');
    loadDashboard();
  });
}

// ==================== HELPERS ====================
async function populateGroupSelect(selectId, type='groups') {
  const sel=document.getElementById(selectId);
  if(!sel) return;
  if(type==='teachers'){
    const items=LC.get('teachers');
    sel.innerHTML='<option value="">-- اختر معلماً --</option>'+items.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  } else {
    const groups=await apiGetGroups();
    sel.innerHTML='<option value="">-- اختر حلقة --</option>'+groups.map(g=>`<option value="${g.id}">${g.name}</option>`).join('');
  }
}

async function deleteItem(store, id, label) {
  showConfirm(`حذف ${label}`,`هل تريد حذف هذا ${label} نهائياً؟`,async()=>{
    LC.del(store, id);
    toast(`🗑️ تم حذف ${label}`,'warning');
    loadPage(currentPage);
  });
}

function printReport() { window.print(); }
function printSchedule() { window.print(); }
function printAttReport() { window.print(); }
function exportPayroll() { toast('📤 جاري تصدير البيانات'); }
function exportExpenses() { toast('📤 جاري تصدير البيانات'); }
function printFeeReport() { window.print(); }

// ==================== OPEN MODAL HOOKS ====================
document.getElementById('addStudentModal').addEventListener('click', ()=>{});
async function openModal(id) {
  if(id==='addStudentModal'){clearStudentForm();document.getElementById('stRegDate').value=today();await populateGroupSelect('stGroup');}
  if(id==='addTeacherModal'){document.getElementById('editTeacherId').value='';}
  if(id==='addGroupModal'){document.getElementById('editGroupId').value='';document.getElementById('gpName').value='';await populateGroupSelect('gpTeacher','teachers');}
  if(id==='addExamModal') await populateGroupSelect('exGroup');
  if(id==='addScheduleModal') await populateGroupSelect('schGroup');
  document.getElementById(id).classList.add('open');
}

// ==================== INIT ====================
async function initApp() {
  const now=new Date();
  document.getElementById('pageDate').textContent=now.toLocaleDateString('ar-SA',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
  updateNotifBadge();
  await loadDashboard();
}

// ==================== LOGIN OVERLAY ====================
// Inject login overlay into page
(function() {
  const overlay = document.createElement('div');
  overlay.id = 'loginOverlay';
  overlay.style.cssText = 'position:fixed;inset:0;background:linear-gradient(135deg,#0a3d2e 0%,#0d5c3a 50%,#1a7a4e 100%);display:flex;align-items:center;justify-content:center;z-index:9999;';
  overlay.innerHTML = `
    <div style="background:#fff;border-radius:24px;padding:40px;width:100%;max-width:420px;box-shadow:0 16px 48px rgba(10,61,46,.22)">
      <div style="text-align:center;margin-bottom:28px">
        <div style="width:72px;height:72px;background:linear-gradient(135deg,#d4a017,#f0c040);border-radius:20px;display:inline-flex;align-items:center;justify-content:center;font-size:36px;box-shadow:0 8px 24px rgba(184,134,11,.4);margin-bottom:16px">🌙</div>
        <h1 style="font-size:24px;font-weight:800;color:#0a3d2e;margin:0">نور القرآن</h1>
        <p style="font-size:13px;color:#8a7a6a;margin-top:4px">نظام الإدارة المتكاملة</p>
      </div>
      <div id="loginErr" style="background:#fdecea;color:#c0392b;border-radius:10px;padding:10px 14px;font-size:13px;margin-bottom:16px;display:none"></div>
      <div style="display:flex;flex-direction:column;gap:5px;margin-bottom:14px">
        <label style="font-size:12px;font-weight:700;color:#4a3728">البريد الإلكتروني</label>
        <input id="loginEmail" type="email" value="admin@quran.dev" style="padding:9px 12px;border:1.5px solid #e0d5c5;border-radius:9px;font-size:13px;font-family:Tajawal,sans-serif;direction:rtl;outline:none" placeholder="admin@quran.dev">
      </div>
      <div style="display:flex;flex-direction:column;gap:5px;margin-bottom:22px">
        <label style="font-size:12px;font-weight:700;color:#4a3728">كلمة المرور</label>
        <input id="loginPass" type="password" value="Admin1234!" style="padding:9px 12px;border:1.5px solid #e0d5c5;border-radius:9px;font-size:13px;font-family:Tajawal,sans-serif;direction:rtl;outline:none" placeholder="••••••••">
      </div>
      <button id="loginBtn" onclick="doLogin()" style="width:100%;padding:11px;background:#0d5c3a;color:#fff;border:none;border-radius:9px;font-size:14px;font-weight:700;cursor:pointer;font-family:Tajawal,sans-serif">🔐 تسجيل الدخول</button>
    </div>
  `;
  document.body.appendChild(overlay);
  document.getElementById('loginPass').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });

  // Add logout link to sidebar footer
  const footer = document.querySelector('.sidebar-footer');
  if (footer) {
    const logoutDiv = document.createElement('div');
    logoutDiv.style.cssText = 'margin-top:8px';
    logoutDiv.innerHTML = '<div class="nav-link" onclick="doLogout()" style="color:rgba(255,255,255,.5);font-size:12px"><span class="nav-icon">🚪</span> تسجيل الخروج</div>';
    footer.appendChild(logoutDiv);
  }

  // Auto-login if token saved
  const saved = localStorage.getItem('qs_token');
  if (saved) {
    _token = saved;
    overlay.style.display = 'none';
    afterLogin().catch(() => { _token=''; overlay.style.display='flex'; });
  }
})();

</script>
</body>
</html>