async function loadExams() {
  const exams = LC.get('exams');
  const groups = await apiGetGroups();
  const gMap={};groups.forEach(g=>gMap[g.id]=g.name);
  const tbody = document.querySelector('#examsTable tbody');
  tbody.innerHTML = exams.map(e=>`
    <tr><td class="td-name">${e.name}</td><td>${gMap[e.groupId]||'-'}</td><td>${e.date||'-'}</td>
    <td>${e.subject==='hafz'?'الحفظ':e.subject==='tajweed'?'التجويد':'الحفظ والتجويد'}</td>
    <td>${e.maxScore||100}</td>
    <td>${e.date>today()?'<span class="badge bb">قادم</span>':e.date===today()?'<span class="badge bg">اليوم</span>':'<span class="badge bgr">منتهي</span>'}</td>
    <td><div class="row-actions"><button class="btn btn-xs btn-danger" onclick="deleteItem('exams',${e.id},'الاختبار')">🗑️</button></div></td></tr>
  `).join('') || '<tr><td colspan="7"><div class="empty"><div class="empty-icon">📝</div><p>لا يوجد اختبارات</p></div></td></tr>';
  await populateGroupSelect('exGroup');
}

async function saveExam() {
  const name = document.getElementById('exName').value.trim();
  if (!name) { toast('اسم الاختبار مطلوب','error'); return; }
  LC.add('exams', {
    name, groupId:document.getElementById('exGroup').value,
    date:document.getElementById('exDate').value||today(),
    subject:document.getElementById('exSubject').value,
    maxScore:Number(document.getElementById('exMaxScore').value)||100,
    passScore:Number(document.getElementById('exPassScore').value)||60
  });
  toast('✅ تم إضافة الاختبار');
  closeModal('addExamModal');
  document.getElementById('exName').value='';
  loadExams();
}

