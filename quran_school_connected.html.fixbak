<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نظام نور القرآن - الإدارة المتكاملة</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Scheherazade+New:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ===================== RESET & VARIABLES ===================== */
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --g1:#0a3d2e;--g2:#0d5c3a;--g3:#1a7a4e;--g4:#22a86a;
  --gold:#b8860b;--gold2:#d4a017;--gold3:#f0c040;--gold4:#fdf3d0;
  --red:#c0392b;--red2:#e74c3c;--red3:#fdecea;
  --blue:#1a5276;--blue2:#2e86c1;--blue3:#d6eaf8;
  --cream:#faf7f2;--cream2:#f5f0e8;--white:#ffffff;
  --border:#e0d5c5;--border2:#c8bfaf;
  --text:#1a1209;--text2:#4a3728;--text3:#8a7a6a;
  --shadow:0 2px 12px rgba(10,61,46,.10);
  --shadow2:0 8px 32px rgba(10,61,46,.16);
  --shadow3:0 16px 48px rgba(10,61,46,.22);
  --radius:12px;--radius2:18px;--radius3:24px;
  --sidebar:260px;--topbar:60px;
  --transition:all .22s cubic-bezier(.4,0,.2,1);
}
body{font-family:'Tajawal',sans-serif;background:var(--cream);color:var(--text);min-height:100vh;display:flex;font-size:14px;line-height:1.5}
button,input,select,textarea{font-family:'Tajawal',sans-serif}
a{text-decoration:none;color:inherit}
/* ===================== SCROLLBAR ===================== */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--cream2)}
::-webkit-scrollbar-thumb{background:var(--g3);border-radius:3px}
/* ===================== SIDEBAR ===================== */
#sidebar{
  width:var(--sidebar);min-height:100vh;background:var(--g1);
  position:fixed;right:0;top:0;z-index:200;
  display:flex;flex-direction:column;
  box-shadow:-2px 0 20px rgba(0,0,0,.3);
  transition:var(--transition);
}
.sidebar-header{
  padding:20px 16px 16px;border-bottom:1px solid rgba(255,255,255,.08);
  display:flex;align-items:center;gap:12px;
}
.sidebar-logo{
  width:44px;height:44px;background:linear-gradient(135deg,var(--gold2),var(--gold3));
  border-radius:12px;display:flex;align-items:center;justify-content:center;
  font-size:22px;box-shadow:0 4px 12px rgba(184,134,11,.4);flex-shrink:0;
}
.sidebar-brand{flex:1}
.sidebar-brand h2{font-size:16px;font-weight:800;color:var(--white);line-height:1.2}
.sidebar-brand p{font-size:10px;color:rgba(255,255,255,.45);margin-top:2px}
.sidebar-nav{flex:1;padding:12px 10px;overflow-y:auto}
.nav-group-title{
  font-size:9px;font-weight:700;color:rgba(255,255,255,.35);
  letter-spacing:1.5px;text-transform:uppercase;padding:14px 8px 6px;
}
.nav-link{
  display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:10px;
  cursor:pointer;color:rgba(255,255,255,.65);font-size:13px;font-weight:500;
  margin-bottom:1px;transition:var(--transition);position:relative;
}
.nav-link:hover{background:rgba(255,255,255,.08);color:var(--white)}
.nav-link.active{background:linear-gradient(90deg,var(--gold2),var(--gold3));color:var(--g1);font-weight:700}
.nav-link .nav-icon{font-size:17px;width:22px;text-align:center;flex-shrink:0}
.nav-badge{
  margin-right:auto;background:var(--red2);color:#fff;
  font-size:9px;font-weight:700;padding:1px 6px;border-radius:10px;
}
.sidebar-footer{
  padding:12px;border-top:1px solid rgba(255,255,255,.08);
}
.user-pill{
  display:flex;align-items:center;gap:10px;padding:10px 12px;
  background:rgba(255,255,255,.07);border-radius:12px;cursor:pointer;
}
.user-pill:hover{background:rgba(255,255,255,.12)}
.user-av{
  width:34px;height:34px;background:linear-gradient(135deg,var(--gold2),var(--gold3));
  border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;
}
.user-pill-info .name{font-size:12px;font-weight:700;color:var(--white)}
.user-pill-info .role{font-size:10px;color:rgba(255,255,255,.4)}
/* ===================== MAIN ===================== */
#main{
  flex:1;margin-right:var(--sidebar);min-height:100vh;
  display:flex;flex-direction:column;
}
#topbar{
  height:var(--topbar);background:var(--white);border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 24px;gap:16px;
  position:sticky;top:0;z-index:100;box-shadow:0 1px 8px rgba(0,0,0,.06);
}
.topbar-title{font-size:18px;font-weight:800;color:var(--g1)}
.topbar-sub{font-size:11px;color:var(--text3);margin-top:1px}
.topbar-spacer{flex:1}
.search-wrap{
  display:flex;align-items:center;gap:8px;background:var(--cream);
  border:1.5px solid var(--border);border-radius:10px;padding:7px 12px;
}
.search-wrap input{border:none;background:none;font-size:13px;color:var(--text);outline:none;width:180px}
@media(max-width:900px){
  #topbar .search-wrap{display:none}
}
.topbar-btn{
  display:flex;align-items:center;gap:6px;padding:7px 14px;border-radius:9px;
  border:none;cursor:pointer;font-size:12px;font-weight:700;transition:var(--transition);
}
.topbar-btn.primary{background:var(--g2);color:#fff}
.topbar-btn.primary:hover{background:var(--g3)}
.topbar-btn.gold{background:var(--gold2);color:#fff}
.topbar-btn.gold:hover{background:var(--gold3);color:var(--g1)}
.topbar-btn.ghost{background:var(--cream);color:var(--text2);border:1.5px solid var(--border)}
.topbar-btn.ghost:hover{background:var(--cream2)}
.notif-btn{
  position:relative;width:36px;height:36px;border-radius:10px;
  background:var(--cream);border:1.5px solid var(--border);
  display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:17px;flex-shrink:0;
}
.notif-dot{
  position:absolute;top:4px;left:4px;width:8px;height:8px;
  background:var(--red2);border-radius:50%;border:1.5px solid var(--white);
}
/* ===================== CONTENT ===================== */
#content{flex:1;padding:24px;overflow-y:auto}
.page{display:none;animation:fadeUp .25s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
/* ===================== COMPONENTS ===================== */
/* Stats */
.stats-row{display:grid;gap:16px;margin-bottom:24px}
.stats-4{grid-template-columns:repeat(4,1fr)}
.stats-3{grid-template-columns:repeat(3,1fr)}
.stat-card{
  background:var(--white);border-radius:var(--radius2);padding:20px;
  border:1px solid var(--border);box-shadow:var(--shadow);
  display:flex;align-items:flex-start;gap:14px;transition:var(--transition);
  position:relative;overflow:hidden;
}
.stat-card::after{
  content:'';position:absolute;top:-20px;left:-20px;width:80px;height:80px;
  border-radius:50%;opacity:.06;
}
.stat-card.green::after{background:var(--g2)}
.stat-card.gold::after{background:var(--gold2)}
.stat-card.blue::after{background:var(--blue2)}
.stat-card.red::after{background:var(--red2)}
.stat-card:hover{transform:translateY(-2px);box-shadow:var(--shadow2)}
.stat-icon-wrap{
  width:46px;height:46px;border-radius:13px;
  display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;
}
.si-green{background:linear-gradient(135deg,#d4edda,#a8d5b5)}
.si-gold{background:linear-gradient(135deg,#fdf3d0,#f0c040)}
.si-blue{background:linear-gradient(135deg,#d6eaf8,#85c1e9)}
.si-red{background:linear-gradient(135deg,#fdecea,#f1948a)}
.si-purple{background:linear-gradient(135deg,#f5eef8,#c39bd3)}
.stat-body{flex:1}
.stat-val{font-size:26px;font-weight:800;color:var(--text);line-height:1}
.stat-lbl{font-size:12px;color:var(--text3);margin-top:3px}
.stat-chg{font-size:11px;margin-top:6px;display:flex;align-items:center;gap:4px}
.chg-up{color:#16a34a}.chg-dn{color:var(--red2)}
/* Card */
.card{background:var(--white);border-radius:var(--radius2);border:1px solid var(--border);box-shadow:var(--shadow);overflow:hidden;margin-bottom:20px}
.card-head{
  padding:16px 20px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.card-title{font-size:15px;font-weight:800;color:var(--g1);display:flex;align-items:center;gap:8px}
.card-body{padding:20px}
/* Table */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
th{
  background:linear-gradient(135deg,#f0f7f3,#e8f5ee);color:var(--g2);
  font-weight:700;padding:11px 14px;text-align:right;border-bottom:2px solid var(--border);
  white-space:nowrap;font-size:12px;
}
td{padding:10px 14px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#f8fcfa}
.td-name{font-weight:700}
/* Badge */
.badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap}
.bg{background:#d1fae5;color:#065f46}
.bb{background:#dbeafe;color:#1e40af}
.by{background:#fef3c7;color:#92400e}
.br{background:#fee2e2;color:#991b1b}
.bp{background:#ede9fe;color:#5b21b6}
.bgr{background:#f3f4f6;color:#374151}
/* Form */
.form-row{display:grid;gap:14px;margin-bottom:14px}
.fr-2{grid-template-columns:1fr 1fr}
.fr-3{grid-template-columns:1fr 1fr 1fr}
.fr-4{grid-template-columns:1fr 1fr 1fr 1fr}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-label{font-size:12px;font-weight:700;color:var(--text2)}
.form-control{
  padding:9px 12px;border:1.5px solid var(--border);border-radius:9px;
  font-size:13px;color:var(--text);background:var(--white);
  transition:var(--transition);direction:rtl;
}
.form-control:focus{outline:none;border-color:var(--g3);box-shadow:0 0 0 3px rgba(26,122,78,.10)}
.form-control::placeholder{color:var(--text3)}
textarea.form-control{resize:vertical;min-height:80px}
select.form-control{cursor:pointer}
.form-hint{font-size:11px;color:var(--text3)}
/* Buttons */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:6px;
  padding:9px 18px;border-radius:9px;border:none;cursor:pointer;
  font-size:13px;font-weight:700;font-family:'Tajawal',sans-serif;transition:var(--transition);
  white-space:nowrap;
}
.btn:disabled{opacity:.5;cursor:not-allowed}
.btn-primary{background:var(--g2);color:#fff}
.btn-primary:hover:not(:disabled){background:var(--g3)}
.btn-gold{background:var(--gold2);color:#fff}
.btn-gold:hover:not(:disabled){background:var(--gold3);color:var(--g1)}
.btn-outline{background:transparent;color:var(--g2);border:1.5px solid var(--g2)}
.btn-outline:hover:not(:disabled){background:#f0f7f3}
.btn-danger{background:var(--red2);color:#fff}
.btn-danger:hover:not(:disabled){background:var(--red)}
.btn-ghost{background:var(--cream);color:var(--text2);border:1.5px solid var(--border)}
.btn-ghost:hover:not(:disabled){background:var(--cream2)}
.btn-sm{padding:5px 12px;font-size:11px;border-radius:7px}
.btn-xs{padding:3px 8px;font-size:10px;border-radius:6px}
.btn-block{width:100%}
.btn-group{display:flex;gap:8px;flex-wrap:wrap}
/* Modal */
.modal-bg{
  position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);
  z-index:500;display:flex;align-items:center;justify-content:center;padding:20px;
  opacity:0;visibility:hidden;transition:var(--transition);
}
.modal-bg.open{opacity:1;visibility:visible}
.modal{
  background:var(--white);border-radius:var(--radius3);width:100%;max-height:90vh;
  overflow-y:auto;box-shadow:var(--shadow3);
  transform:scale(.95) translateY(20px);transition:var(--transition);
}
.modal-bg.open .modal{transform:scale(1) translateY(0)}
.modal-sm{max-width:420px}
.modal-md{max-width:600px}
.modal-lg{max-width:780px}
.modal-xl{max-width:960px}
.modal-head{
  padding:20px 24px 16px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--white);z-index:1;
}
.modal-title{font-size:18px;font-weight:800;color:var(--g1)}
.modal-close{
  width:32px;height:32px;border-radius:8px;border:none;background:var(--cream);
  cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center;transition:var(--transition);
}
.modal-close:hover{background:#fee2e2;color:var(--red2)}
.modal-body{padding:22px 24px}
.modal-foot{padding:16px 24px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end}
/* Tabs */
.tabs-wrap{display:flex;gap:2px;background:var(--cream2);padding:4px;border-radius:11px;margin-bottom:20px}
.tab-btn{
  flex:1;padding:8px 12px;border-radius:8px;border:none;background:transparent;
  cursor:pointer;font-size:12px;font-weight:700;color:var(--text3);transition:var(--transition);
  font-family:'Tajawal',sans-serif;
}
.tab-btn.active{background:var(--white);color:var(--g1);box-shadow:var(--shadow)}
/* Progress */
.prog-wrap{height:8px;background:var(--cream2);border-radius:4px;overflow:hidden}
.prog-fill{height:100%;border-radius:4px;transition:width .6s ease}
.prog-green{background:linear-gradient(90deg,var(--g2),var(--g4))}
.prog-gold{background:linear-gradient(90deg,var(--gold),var(--gold3))}
.prog-blue{background:linear-gradient(90deg,var(--blue),var(--blue2))}
.prog-red{background:linear-gradient(90deg,var(--red),var(--red2))}
/* Grid */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
/* Alert */
.alert{padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px}
.alert-success{background:#d1fae5;color:#065f46;border:1px solid #a7f3d0}
.alert-warning{background:#fef3c7;color:#92400e;border:1px solid #fde68a}
.alert-danger{background:#fee2e2;color:#991b1b;border:1px solid #fecaca}
.alert-info{background:#dbeafe;color:#1e40af;border:1px solid #bfdbfe}
/* Avatar */
.av{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.av-green{background:linear-gradient(135deg,var(--g2),var(--g4))}
.av-gold{background:linear-gradient(135deg,var(--gold),var(--gold3))}
.av-blue{background:linear-gradient(135deg,var(--blue),var(--blue2))}
/* Divider */
.divider{height:1px;background:var(--border);margin:16px 0}
/* Chip */
.chip{display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border-radius:20px;font-size:12px;background:var(--cream2);color:var(--text2)}
/* Toast */
#toast-container{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:10px;pointer-events:none}
.toast{
  background:var(--g1);color:var(--white);padding:12px 22px;border-radius:12px;
  font-size:13px;font-weight:600;box-shadow:var(--shadow3);
  animation:toastIn .3s ease;display:flex;align-items:center;gap:8px;
  min-width:260px;justify-content:center;
}
.toast.success{background:var(--g2)}
.toast.error{background:var(--red)}
.toast.warning{background:var(--gold)}
@keyframes toastIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
/* Chart bars */
.bar-chart{display:flex;align-items:flex-end;gap:8px;height:160px;padding-bottom:24px}
.bar-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.bar{border-radius:6px 6px 0 0;width:100%;min-height:4px;transition:height .5s ease}
.bar-lbl{font-size:10px;color:var(--text3);white-space:nowrap;position:absolute;bottom:-20px}
/* Quran map */
.quran-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:6px}
.juz-item{
  padding:8px 4px;border-radius:8px;text-align:center;cursor:pointer;
  border:1.5px solid var(--border);transition:var(--transition);
}
.juz-item:hover{border-color:var(--g3)}
.juz-done{background:#d1fae5;border-color:#34d399}
.juz-partial{background:#fef3c7;border-color:#fbbf24}
.juz-none{background:var(--cream)}
.juz-num{font-size:16px;font-weight:800;color:var(--g1);font-family:'Scheherazade New',serif}
.juz-lbl{font-size:9px;color:var(--text3);margin-top:2px}
/* Summary box */
.summary-box{background:var(--cream2);border-radius:12px;padding:14px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;text-align:center}
.summary-val{font-size:22px;font-weight:800;color:var(--text)}
.summary-lbl{font-size:11px;color:var(--text3)}
/* Calendar */
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center}
.cal-head{font-size:10px;font-weight:700;color:var(--text3);padding:4px}
.cal-day{
  padding:6px 2px;border-radius:6px;font-size:12px;cursor:default;
  position:relative;
}
.cal-present{background:#d1fae5;color:#065f46;font-weight:700}
.cal-absent{background:#fee2e2;color:#991b1b;font-weight:700}
.cal-excused{background:#fef3c7;color:#92400e;font-weight:700}
.cal-off{background:var(--cream2);color:var(--text3)}
.cal-today{outline:2px solid var(--g3)}
/* Salary card */
.salary-card{
  background:linear-gradient(135deg,var(--g1) 0%,var(--g2) 60%,var(--g3) 100%);
  border-radius:var(--radius2);padding:22px 24px;color:var(--white);
  position:relative;overflow:hidden;margin-bottom:20px;
}
.salary-card::before{
  content:'﷽';position:absolute;top:-20px;left:-10px;font-size:100px;
  opacity:.04;font-family:'Scheherazade New',serif;line-height:1;
}
.salary-card h3{font-size:13px;opacity:.7;margin-bottom:8px}
.salary-card .amount{font-size:34px;font-weight:800}
.salary-card .sub{font-size:12px;opacity:.6;margin-top:4px}
/* Print area */
@media print{
  #sidebar,#topbar,.no-print{display:none!important}
  #main{margin-right:0}
  .print-area{display:block!important}
}
/* Responsive */
@media(max-width:1200px){
  .stats-4{grid-template-columns:repeat(2,1fr)}
  .g4{grid-template-columns:repeat(2,1fr)}
}
/* ===== MOBILE HAMBURGER ===== */
#menuToggle{
  display:none;width:40px;height:40px;border-radius:10px;
  border:none;background:var(--cream);border:1.5px solid var(--border);
  font-size:20px;cursor:pointer;align-items:center;justify-content:center;
  flex-shrink:0;
}
#sidebarOverlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);
  z-index:150;backdrop-filter:blur(2px);
}
@media(max-width:900px){
  #menuToggle{display:flex}
  #sidebar{
    transform:translateX(100%);transition:transform .28s cubic-bezier(.4,0,.2,1);
    z-index:300;
  }
  #sidebar.open{transform:translateX(0)}
  #sidebarOverlay.open{display:block}
  #main{margin-right:0}
  #topbar{padding:0 14px;gap:10px}
  .topbar-title{font-size:15px}
  .topbar-sub{display:none}
  #content{padding:14px}
  .stats-row,.stats-4,.stats-3{grid-template-columns:repeat(2,1fr)}
  .g2,.g3,.g4{grid-template-columns:1fr}
  .fr-2,.fr-3,.fr-4{grid-template-columns:1fr}
  .modal{width:95vw!important;max-width:95vw!important}
  .modal-body{padding:16px}
  .modal-head{padding:16px 16px 12px}
  .modal-foot{padding:12px 16px}
  .card-head{flex-wrap:wrap;gap:8px}
  .action-row{flex-direction:column;align-items:stretch}
  .action-row .btn-group,.action-row>div{width:100%}
  .search-wrap{width:100%}
  .search-wrap input{width:100%}
  .btn-group{flex-wrap:wrap}
  .tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
  table{min-width:500px}
  .tabs-wrap{overflow-x:auto;white-space:nowrap;display:flex;gap:2px;padding:4px}
  .tab-btn{flex:0 0 auto;padding:8px 14px;font-size:11px}
  .quran-grid{grid-template-columns:repeat(5,1fr)}
  .form-row{grid-template-columns:1fr!important}
  .stats-row.stats-4{grid-template-columns:repeat(2,1fr)}
  .stats-row.stats-3{grid-template-columns:repeat(2,1fr)}
  .summary-box{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:480px){
  .stats-row,.stats-4,.stats-3{grid-template-columns:1fr}
  .stats-row.stats-4{grid-template-columns:1fr}
  .stat-val{font-size:22px}
  .quran-grid{grid-template-columns:repeat(4,1fr)}
  #content{padding:10px}
  .card-body{padding:14px}
  .topbar-btn.gold{display:none}
  .summary-box{grid-template-columns:1fr;gap:8px}
}
/* Loading */
.loading{display:flex;align-items:center;justify-content:center;padding:40px;color:var(--text3);gap:12px}
.spinner{width:24px;height:24px;border:3px solid var(--border);border-top-color:var(--g3);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
/* Empty state */
.empty{text-align:center;padding:48px 20px;color:var(--text3)}
.empty .empty-icon{font-size:48px;margin-bottom:12px}
.empty h4{font-size:16px;font-weight:700;color:var(--text2);margin-bottom:6px}
.empty p{font-size:13px}
/* Action row */
.action-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap}
/* Info row */
.info-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.info-item{background:var(--cream2);border-radius:8px;padding:8px 12px;flex:1;min-width:120px}
.info-item .lbl{font-size:10px;color:var(--text3);margin-bottom:2px}
.info-item .val{font-size:14px;font-weight:700;color:var(--text)}
/* Table row actions */
.row-actions{display:flex;gap:4px}
/* Floating label */
.fl-label{
  font-size:10px;font-weight:700;color:var(--g2);background:var(--white);
  padding:0 4px;position:relative;top:-1px;
}
</style>
</head>
<body>

<!-- ==================== SIDEBAR ==================== -->
<nav id="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-logo">🌙</div>
    <div class="sidebar-brand">
      <h2>نور القرآن</h2>
      <p>نظام الإدارة المتكاملة</p>
    </div>
  </div>
  <div class="sidebar-nav" id="sidebarNav">
    <div class="nav-group-title">الرئيسية</div>
    <div class="nav-link active" data-page="dashboard"><span class="nav-icon">🏠</span> لوحة التحكم</div>

    <div class="nav-group-title">إدارة الطلاب</div>
    <div class="nav-link" data-page="students"><span class="nav-icon">👨‍🎓</span> الطلاب</div>
    <div class="nav-link" data-page="attendance"><span class="nav-icon">✅</span> الحضور والغياب</div>
    <div class="nav-link" data-page="memorization"><span class="nav-icon">📖</span> متابعة الحفظ</div>
    <div class="nav-link" data-page="recitation"><span class="nav-icon">🎙️</span> التسميع والتجويد</div>
    <div class="nav-link" data-page="exams"><span class="nav-icon">📝</span> الاختبارات</div>

    <div class="nav-group-title">إدارة الكوادر</div>
    <div class="nav-link" data-page="teachers"><span class="nav-icon">👨‍🏫</span> المعلمون</div>
    <div class="nav-link" data-page="groups"><span class="nav-icon">👥</span> الحلقات والمجموعات</div>
    <div class="nav-link" data-page="schedule"><span class="nav-icon">📅</span> الجدول الدراسي</div>

    <div class="nav-group-title">الشؤون المالية</div>
    <div class="nav-link" data-page="fees"><span class="nav-icon">💳</span> رسوم الطلاب</div>
    <div class="nav-link" data-page="payroll"><span class="nav-icon">💰</span> الرواتب والأجور</div>
    <div class="nav-link" data-page="expenses"><span class="nav-icon">📊</span> المصروفات</div>

    <div class="nav-group-title">التقارير والإعدادات</div>
    <div class="nav-link" data-page="reports"><span class="nav-icon">📈</span> التقارير والإحصاء</div>
    <div class="nav-link" data-page="notifications"><span class="nav-icon">🔔</span> الإشعارات <span class="nav-badge" id="notifBadge">0</span></div>
    <div class="nav-link" data-page="settings"><span class="nav-icon">⚙️</span> إعدادات النظام</div>
  </div>
  <div class="sidebar-footer">
    <div class="user-pill">
      <div class="user-av">👤</div>
      <div class="user-pill-info">
        <div class="name" id="adminName">مدير النظام</div>
        <div class="role">مدير المدرسة</div>
      </div>
    </div>
  </div>
</nav>

<!-- ==================== MAIN ==================== -->
<div id="main">
  <!-- Mobile Sidebar Overlay -->
  <div id="sidebarOverlay" onclick="closeSidebar()"></div>

  <header id="topbar">
    <button id="menuToggle" onclick="toggleSidebar()" aria-label="القائمة">☰</button>
    <div>
      <div class="topbar-title" id="pageTitle">لوحة التحكم</div>
      <div class="topbar-sub" id="pageDate"></div>
    </div>
    <div class="topbar-spacer"></div>
    <div class="search-wrap">
      <span>🔍</span>
      <input type="text" placeholder="بحث في النظام..." id="globalSearch">
    </div>
    <button class="topbar-btn gold" onclick="openModal('addStudentModal')">➕ طالب جديد</button>
    <div class="notif-btn" onclick="navigate('notifications')"><span>🔔</span><div class="notif-dot" id="notifDot" style="display:none"></div></div>
  </header>

  <div id="content">

    <!-- ==================== DASHBOARD ==================== -->
    <div class="page active" id="page-dashboard">
      <div class="stats-row stats-4" id="dashStats"></div>
      <div class="g2">
        <div>
          <div class="card">
            <div class="card-head">
              <span class="card-title">📊 الحضور الأسبوعي</span>
              <span class="badge bg" id="avgAttBadge">-</span>
            </div>
            <div class="card-body">
              <div class="bar-chart" id="attendanceChart"></div>
            </div>
          </div>
          <div class="card">
            <div class="card-head"><span class="card-title">⭐ أوائل الطلاب</span></div>
            <div class="tbl-wrap"><table id="topStudentsTable">
              <thead><tr><th>#</th><th>الطالب</th><th>المحفوظ</th><th>الحضور</th><th>التقييم</th></tr></thead>
              <tbody></tbody>
            </table></div>
          </div>
        </div>
        <div>
          <div class="card">
            <div class="card-head"><span class="card-title">📈 تقدم الحفظ الإجمالي</span></div>
            <div class="card-body" id="memorizationProgress"></div>
          </div>
          <div class="card">
            <div class="card-head">
              <span class="card-title">🔔 آخر الإشعارات</span>
              <span class="badge br" id="dashNotifCount">0</span>
            </div>
            <div class="card-body" id="dashNotifications" style="padding:4px 20px"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== STUDENTS ==================== -->
    <div class="page" id="page-students">
      <div class="action-row">
        <div class="search-wrap"><span>🔍</span><input type="text" placeholder="بحث عن طالب..." id="studentSearch" oninput="filterStudents()"></div>
        <div style="display:flex;gap:8px;align-items:center">
          <select class="form-control" id="filterGroup" onchange="filterStudents()" style="width:160px">
            <option value="">كل الحلقات</option>
          </select>
          <select class="form-control" id="filterStatus" onchange="filterStudents()" style="width:130px">
            <option value="">كل الحالات</option>
            <option value="active">نشط</option>
            <option value="inactive">موقوف</option>
          </select>
          <button class="btn btn-primary" onclick="openModal('addStudentModal')">➕ إضافة طالب</button>
          <button class="btn btn-ghost" onclick="exportStudents()">📤 تصدير</button>
        </div>
      </div>
      <div class="card">
        <div class="card-head">
          <span class="card-title">👨‍🎓 قائمة الطلاب</span>
          <span class="badge bg" id="studentsCount">0 طالب</span>
        </div>
        <div class="tbl-wrap">
          <table id="studentsTable">
            <thead><tr><th>#</th><th>الاسم</th><th>العمر</th><th>الحلقة</th><th>المحفوظ</th><th>الحضور</th><th>الرسوم</th><th>الحالة</th><th>الإجراءات</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ==================== ATTENDANCE ==================== -->
    <div class="page" id="page-attendance">
      <div class="g2" style="margin-bottom:20px">
        <div class="card">
          <div class="card-head">
            <span class="card-title">✅ تسجيل حضور اليوم</span>
          </div>
          <div class="card-body">
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">الحلقة</label>
                <select class="form-control" id="attGroup" onchange="loadAttendanceStudents()"></select>
              </div>
              <div class="form-group">
                <label class="form-label">التاريخ</label>
                <input type="date" class="form-control" id="attDate" value="">
              </div>
            </div>
            <div id="attStudentsList"></div>
            <div class="btn-group" style="margin-top:14px">
              <button class="btn btn-primary btn-block" onclick="saveAttendance()">💾 حفظ الحضور</button>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-head">
            <span class="card-title">📅 سجل حضور الطالب</span>
          </div>
          <div class="card-body">
            <div class="form-group" style="margin-bottom:12px">
              <label class="form-label">اختر الطالب</label>
              <select class="form-control" id="attStudentSelect" onchange="loadStudentCalendar()"></select>
            </div>
            <div class="form-group" style="margin-bottom:12px">
              <label class="form-label">الشهر</label>
              <input type="month" class="form-control" id="attMonth" onchange="loadStudentCalendar()">
            </div>
            <div id="studentCalendar"></div>
            <div id="attSummary" style="margin-top:12px"></div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-head">
          <span class="card-title">📋 تقرير الحضور اليومي</span>
          <button class="btn btn-ghost btn-sm" onclick="printAttReport()">🖨️ طباعة</button>
        </div>
        <div class="tbl-wrap">
          <table id="dailyAttTable">
            <thead><tr><th>الطالب</th><th>الحلقة</th><th>التاريخ</th><th>الحالة</th><th>ملاحظة</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ==================== MEMORIZATION ==================== -->
    <div class="page" id="page-memorization">
      <div class="g2">
        <div>
          <div class="card">
            <div class="card-head"><span class="card-title">📖 تسجيل حفظ جديد</span></div>
            <div class="card-body">
              <div class="form-row fr-1">
                <div class="form-group">
                  <label class="form-label">الطالب</label>
                  <select class="form-control" id="memStudent" onchange="loadStudentProgress()"></select>
                </div>
              </div>
              <div class="form-row fr-2">
                <div class="form-group">
                  <label class="form-label">السورة</label>
                  <select class="form-control" id="memSurah"></select>
                </div>
                <div class="form-group">
                  <label class="form-label">الجزء</label>
                  <select class="form-control" id="memJuz">
                    <option value="">-- الجزء --</option>
                  </select>
                </div>
              </div>
              <div class="form-row fr-2">
                <div class="form-group">
                  <label class="form-label">من آية</label>
                  <input type="number" class="form-control" id="memFrom" min="1" placeholder="1">
                </div>
                <div class="form-group">
                  <label class="form-label">إلى آية</label>
                  <input type="number" class="form-control" id="memTo" placeholder="آخر آية">
                </div>
              </div>
              <div class="form-row fr-2">
                <div class="form-group">
                  <label class="form-label">النوع</label>
                  <select class="form-control" id="memType">
                    <option value="new">حفظ جديد</option>
                    <option value="review">مراجعة</option>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">التقييم</label>
                  <select class="form-control" id="memGrade">
                    <option value="5">ممتاز ⭐⭐⭐</option>
                    <option value="4">جيد جداً ⭐⭐</option>
                    <option value="3">جيد ⭐</option>
                    <option value="2">مقبول</option>
                    <option value="1">ضعيف</option>
                  </select>
                </div>
              </div>
              <div class="form-group" style="margin-bottom:14px">
                <label class="form-label">ملاحظات المعلم</label>
                <textarea class="form-control" id="memNotes" placeholder="ملاحظات حول جلسة الحفظ..."></textarea>
              </div>
              <button class="btn btn-primary btn-block" onclick="saveMemorization()">💾 تسجيل الحفظ</button>
            </div>
          </div>
        </div>
        <div>
          <div class="card">
            <div class="card-head">
              <span class="card-title">🗺️ خريطة حفظ الطالب</span>
            </div>
            <div class="card-body">
              <div id="studentProgressMap">
                <div class="empty"><div class="empty-icon">📖</div><p>اختر طالباً لعرض تقدمه</p></div>
              </div>
            </div>
          </div>
          <div class="card">
            <div class="card-head"><span class="card-title">📋 سجل الحفظ الأخير</span></div>
            <div class="tbl-wrap">
              <table id="memLogTable">
                <thead><tr><th>التاريخ</th><th>الطالب</th><th>السورة</th><th>النوع</th><th>التقييم</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== RECITATION ==================== -->
    <div class="page" id="page-recitation">
      <div class="g2">
        <div class="card">
          <div class="card-head"><span class="card-title">🎙️ تسجيل جلسة تسميع</span></div>
          <div class="card-body">
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">الطالب</label>
                <select class="form-control" id="recStudent"></select>
              </div>
              <div class="form-group">
                <label class="form-label">نوع الجلسة</label>
                <select class="form-control" id="recType">
                  <option value="hafz">تسميع حفظ جديد</option>
                  <option value="muraja">مراجعة محفوظات</option>
                  <option value="tajweed">تجويد وتحسين</option>
                  <option value="exam">اختبار دوري</option>
                </select>
              </div>
            </div>
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">السورة</label>
                <select class="form-control" id="recSurah"></select>
              </div>
              <div class="form-group">
                <label class="form-label">الصفحات</label>
                <input type="text" class="form-control" id="recPages" placeholder="مثال: 15-20">
              </div>
            </div>
            <div class="form-group" style="margin-bottom:12px">
              <label class="form-label">أخطاء التجويد (اختر ما ينطبق)</label>
              <div style="display:flex;flex-wrap:wrap;gap:6px;padding:10px;background:var(--cream);border-radius:9px">
                <label style="display:flex;align-items:center;gap:5px;font-size:12px"><input type="checkbox" value="medd"> المد</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:12px"><input type="checkbox" value="ghunna"> الغنة</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:12px"><input type="checkbox" value="qalb"> القلب</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:12px"><input type="checkbox" value="idgham"> الإدغام</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:12px"><input type="checkbox" value="ikhfa"> الإخفاء</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:12px"><input type="checkbox" value="waqf"> الوقف</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:12px"><input type="checkbox" value="mahrj"> المخارج</label>
              </div>
            </div>
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">درجة التجويد (من 10)</label>
                <input type="number" class="form-control" id="recTajweedScore" min="0" max="10" placeholder="10">
              </div>
              <div class="form-group">
                <label class="form-label">درجة الحفظ (من 10)</label>
                <input type="number" class="form-control" id="recHafzScore" min="0" max="10" placeholder="10">
              </div>
            </div>
            <div class="form-group" style="margin-bottom:14px">
              <label class="form-label">ملاحظات</label>
              <textarea class="form-control" id="recNotes" rows="3" placeholder="ملاحظات المعلم..."></textarea>
            </div>
            <button class="btn btn-primary btn-block" onclick="saveRecitation()">💾 حفظ جلسة التسميع</button>
          </div>
        </div>
        <div>
          <div class="card">
            <div class="card-head"><span class="card-title">📋 سجلات التسميع</span></div>
            <div class="tbl-wrap">
              <table id="recLogTable">
                <thead><tr><th>التاريخ</th><th>الطالب</th><th>النوع</th><th>الحفظ</th><th>التجويد</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== EXAMS ==================== -->
    <div class="page" id="page-exams">
      <div class="action-row">
        <h3 style="color:var(--g1)">الاختبارات والتقييمات</h3>
        <button class="btn btn-primary" onclick="openModal('addExamModal')">➕ اختبار جديد</button>
      </div>
      <div class="card">
        <div class="tbl-wrap">
          <table id="examsTable">
            <thead><tr><th>اسم الاختبار</th><th>الحلقة</th><th>التاريخ</th><th>المادة</th><th>الدرجة العظمى</th><th>الحالة</th><th>الإجراءات</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ==================== TEACHERS ==================== -->
    <div class="page" id="page-teachers">
      <div class="action-row">
        <div class="search-wrap"><span>🔍</span><input type="text" placeholder="بحث عن معلم..." id="teacherSearch" oninput="filterTeachers()"></div>
        <button class="btn btn-primary" onclick="openModal('addTeacherModal')">➕ إضافة معلم</button>
      </div>
      <div id="teachersGrid" class="g3"></div>
    </div>

    <!-- ==================== GROUPS ==================== -->
    <div class="page" id="page-groups">
      <div class="action-row">
        <h3 style="color:var(--g1)">الحلقات والمجموعات</h3>
        <button class="btn btn-primary" onclick="openModal('addGroupModal')">➕ حلقة جديدة</button>
      </div>
      <div id="groupsGrid" class="g3"></div>
    </div>

    <!-- ==================== SCHEDULE ==================== -->
    <div class="page" id="page-schedule">
      <div class="action-row">
        <h3 style="color:var(--g1)">الجدول الدراسي الأسبوعي</h3>
        <div class="btn-group">
          <button class="btn btn-ghost btn-sm" onclick="printSchedule()">🖨️ طباعة</button>
          <button class="btn btn-primary" onclick="openModal('addScheduleModal')">➕ إضافة موعد</button>
        </div>
      </div>
      <div class="card">
        <div class="card-body" id="scheduleBoard"></div>
      </div>
    </div>

    <!-- ==================== FEES ==================== -->
    <div class="page" id="page-fees">
      <div class="stats-row stats-4" id="feeStats"></div>
      <div class="g2">
        <div class="card">
          <div class="card-head">
            <span class="card-title">💳 تسجيل دفعة</span>
          </div>
          <div class="card-body">
            <div class="form-group" style="margin-bottom:12px">
              <label class="form-label">الطالب</label>
              <select class="form-control" id="feeStudent"></select>
            </div>
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">المبلغ (ريال)</label>
                <input type="number" class="form-control" id="feeAmount" placeholder="500">
              </div>
              <div class="form-group">
                <label class="form-label">طريقة الدفع</label>
                <select class="form-control" id="feeMethod">
                  <option value="cash">نقداً</option>
                  <option value="transfer">تحويل بنكي</option>
                  <option value="card">بطاقة</option>
                  <option value="app">تطبيق دفع</option>
                </select>
              </div>
            </div>
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">الشهر</label>
                <input type="month" class="form-control" id="feeMonth">
              </div>
              <div class="form-group">
                <label class="form-label">التاريخ</label>
                <input type="date" class="form-control" id="feeDate">
              </div>
            </div>
            <div class="form-group" style="margin-bottom:14px">
              <label class="form-label">ملاحظة</label>
              <input type="text" class="form-control" id="feeNote" placeholder="ملاحظة اختيارية">
            </div>
            <button class="btn btn-primary btn-block" onclick="saveFeePayment()">💾 تسجيل الدفعة</button>
          </div>
        </div>
        <div class="card">
          <div class="card-head">
            <span class="card-title">📋 سجل المدفوعات</span>
            <button class="btn btn-ghost btn-sm" onclick="printFeeReport()">🖨️ طباعة</button>
          </div>
          <div class="tbl-wrap">
            <table id="feesTable">
              <thead><tr><th>الطالب</th><th>المبلغ</th><th>الشهر</th><th>طريقة الدفع</th><th>التاريخ</th><th>إيصال</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-head">
          <span class="card-title">⚠️ الرسوم المتأخرة</span>
          <span class="badge br" id="overdueCount">0</span>
        </div>
        <div class="tbl-wrap">
          <table id="overdueTable">
            <thead><tr><th>الطالب</th><th>الأشهر المتأخرة</th><th>المبلغ المستحق</th><th>جوال ولي الأمر</th><th>إجراء</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ==================== PAYROLL ==================== -->
    <div class="page" id="page-payroll">
      <div class="stats-row stats-3" id="payrollStats"></div>
      <div class="tabs-wrap">
        <button class="tab-btn active" onclick="switchTab(this,'payroll-run')">صرف الرواتب</button>
        <button class="tab-btn" onclick="switchTab(this,'payroll-history')">سجل الرواتب</button>
        <button class="tab-btn" onclick="switchTab(this,'payroll-settings')">إعدادات الرواتب</button>
      </div>
      <!-- Run Payroll -->
      <div id="payroll-run">
        <div class="g2">
          <div class="card">
            <div class="card-head"><span class="card-title">💰 صرف رواتب الشهر</span></div>
            <div class="card-body">
              <div class="form-row fr-2">
                <div class="form-group">
                  <label class="form-label">الشهر</label>
                  <input type="month" class="form-control" id="payrollMonth">
                </div>
                <div class="form-group">
                  <label class="form-label">تاريخ الصرف</label>
                  <input type="date" class="form-control" id="payrollDate">
                </div>
              </div>
              <div id="payrollTeachersList"></div>
              <div class="divider"></div>
              <div class="summary-box" id="payrollSummary" style="margin-bottom:16px">
                <div><div class="summary-val" id="totalSalary">0</div><div class="summary-lbl">إجمالي الرواتب (ريال)</div></div>
                <div><div class="summary-val" id="totalAllowances">0</div><div class="summary-lbl">إجمالي البدلات</div></div>
                <div><div class="summary-val" id="totalDeductions">0</div><div class="summary-lbl">إجمالي الخصومات</div></div>
              </div>
              <button class="btn btn-primary btn-block" onclick="runPayroll()">💸 صرف الرواتب</button>
            </div>
          </div>
          <div class="card">
            <div class="card-head"><span class="card-title">👤 تعديل راتب موظف</span></div>
            <div class="card-body">
              <div class="form-group" style="margin-bottom:12px">
                <label class="form-label">الموظف</label>
                <select class="form-control" id="salaryTeacher" onchange="loadTeacherSalary()"></select>
              </div>
              <div id="teacherSalaryForm"></div>
            </div>
          </div>
        </div>
      </div>
      <!-- History -->
      <div id="payroll-history" style="display:none">
        <div class="card">
          <div class="card-head">
            <span class="card-title">📋 سجل الرواتب المصروفة</span>
            <button class="btn btn-ghost btn-sm" onclick="exportPayroll()">📤 تصدير</button>
          </div>
          <div class="tbl-wrap">
            <table id="payrollTable">
              <thead><tr><th>الموظف</th><th>الشهر</th><th>الراتب الأساسي</th><th>البدلات</th><th>الخصومات</th><th>الصافي</th><th>التاريخ</th><th>إجراء</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </div>
      <!-- Settings -->
      <div id="payroll-settings" style="display:none">
        <div class="card">
          <div class="card-head"><span class="card-title">⚙️ إعدادات الرواتب</span></div>
          <div class="card-body">
            <div class="alert alert-info">⚠️ يتم حساب الرواتب بناءً على ساعات العمل، الحضور، والبدلات المحددة لكل موظف</div>
            <div class="form-row fr-3">
              <div class="form-group">
                <label class="form-label">بدل السكن (%)</label>
                <input type="number" class="form-control" id="housingAllowance" value="25">
              </div>
              <div class="form-group">
                <label class="form-label">بدل النقل (%)</label>
                <input type="number" class="form-control" id="transportAllowance" value="10">
              </div>
              <div class="form-group">
                <label class="form-label">خصم الغياب (ريال/يوم)</label>
                <input type="number" class="form-control" id="absenceDeduction" value="200">
              </div>
            </div>
            <div class="form-row fr-3">
              <div class="form-group">
                <label class="form-label">مكافأة التميز (ريال)</label>
                <input type="number" class="form-control" id="excellenceBonus" value="500">
              </div>
              <div class="form-group">
                <label class="form-label">الضريبة (%)</label>
                <input type="number" class="form-control" id="taxRate" value="0">
              </div>
              <div class="form-group">
                <label class="form-label">GOSI (%)</label>
                <input type="number" class="form-control" id="gosiRate" value="10">
              </div>
            </div>
            <button class="btn btn-primary" onclick="savePayrollSettings()">💾 حفظ الإعدادات</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ==================== EXPENSES ==================== -->
    <div class="page" id="page-expenses">
      <div class="g2">
        <div class="card">
          <div class="card-head"><span class="card-title">💸 تسجيل مصروف</span></div>
          <div class="card-body">
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">نوع المصروف</label>
                <select class="form-control" id="expCategory">
                  <option value="utilities">كهرباء وماء</option>
                  <option value="supplies">لوازم مكتبية</option>
                  <option value="maintenance">صيانة</option>
                  <option value="books">كتب ومطبوعات</option>
                  <option value="events">فعاليات وأنشطة</option>
                  <option value="other">أخرى</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">المبلغ (ريال)</label>
                <input type="number" class="form-control" id="expAmount" placeholder="0">
              </div>
            </div>
            <div class="form-row fr-2">
              <div class="form-group">
                <label class="form-label">التاريخ</label>
                <input type="date" class="form-control" id="expDate">
              </div>
              <div class="form-group">
                <label class="form-label">طريقة الدفع</label>
                <select class="form-control" id="expMethod">
                  <option value="cash">نقداً</option>
                  <option value="transfer">تحويل</option>
                  <option value="card">بطاقة</option>
                </select>
              </div>
            </div>
            <div class="form-group" style="margin-bottom:14px">
              <label class="form-label">الوصف</label>
              <textarea class="form-control" id="expDesc" rows="3" placeholder="وصف المصروف..."></textarea>
            </div>
            <button class="btn btn-primary btn-block" onclick="saveExpense()">💾 تسجيل المصروف</button>
          </div>
        </div>
        <div>
          <div class="stats-row stats-3" id="expStats"></div>
          <div class="card">
            <div class="card-head"><span class="card-title">📊 المصروفات حسب الفئة</span></div>
            <div class="card-body" id="expChart"></div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-head">
          <span class="card-title">📋 سجل المصروفات</span>
          <button class="btn btn-ghost btn-sm" onclick="exportExpenses()">📤 تصدير</button>
        </div>
        <div class="tbl-wrap">
          <table id="expensesTable">
            <thead><tr><th>الفئة</th><th>المبلغ</th><th>الوصف</th><th>طريقة الدفع</th><th>التاريخ</th><th>إجراء</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ==================== REPORTS ==================== -->
    <div class="page" id="page-reports">
      <div class="tabs-wrap">
        <button class="tab-btn active" onclick="switchTab(this,'rep-overview')">نظرة عامة</button>
        <button class="tab-btn" onclick="switchTab(this,'rep-students')">تقارير الطلاب</button>
        <button class="tab-btn" onclick="switchTab(this,'rep-financial')">التقارير المالية</button>
      </div>
      <div id="rep-overview">
        <div class="stats-row stats-4" id="repStats"></div>
        <div class="g2">
          <div class="card">
            <div class="card-head"><span class="card-title">📈 نمو الطلاب شهرياً</span></div>
            <div class="card-body"><div class="bar-chart" id="repGrowthChart"></div></div>
          </div>
          <div class="card">
            <div class="card-head"><span class="card-title">💰 الملخص المالي</span></div>
            <div class="card-body" id="repFinancialSummary"></div>
          </div>
        </div>
      </div>
      <div id="rep-students" style="display:none">
        <div class="action-row">
          <div class="form-row fr-3" style="flex:1;gap:10px">
            <div class="form-group">
              <select class="form-control" id="repGroup"><option value="">كل الحلقات</option></select>
            </div>
            <div class="form-group">
              <input type="month" class="form-control" id="repMonth">
            </div>
            <div class="form-group">
              <button class="btn btn-primary" onclick="generateStudentReport()">📊 توليد التقرير</button>
            </div>
          </div>
          <button class="btn btn-ghost" onclick="printReport('rep-students')">🖨️ طباعة</button>
        </div>
        <div id="studentReportContent"></div>
      </div>
      <div id="rep-financial" style="display:none">
        <div class="action-row">
          <div class="form-row fr-2" style="flex:1;gap:10px">
            <div class="form-group">
              <input type="month" class="form-control" id="repFinMonth">
            </div>
            <div class="form-group">
              <button class="btn btn-primary" onclick="generateFinancialReport()">📊 توليد التقرير</button>
            </div>
          </div>
          <button class="btn btn-ghost" onclick="printReport('rep-financial')">🖨️ طباعة</button>
        </div>
        <div id="financialReportContent"></div>
      </div>
    </div>

    <!-- ==================== NOTIFICATIONS ==================== -->
    <div class="page" id="page-notifications">
      <div class="action-row">
        <h3 style="color:var(--g1)">مركز الإشعارات</h3>
        <div class="btn-group">
          <button class="btn btn-ghost btn-sm" onclick="markAllRead()">✓ تحديد الكل كمقروء</button>
          <button class="btn btn-danger btn-sm" onclick="clearNotifications()">🗑️ مسح الكل</button>
        </div>
      </div>
      <div class="card">
        <div class="card-body" id="notificationsList"></div>
      </div>
    </div>

    <!-- ==================== SETTINGS ==================== -->
    <div class="page" id="page-settings">
      <div class="tabs-wrap">
        <button class="tab-btn active" onclick="switchTab(this,'set-school')">المدرسة</button>
        <button class="tab-btn" onclick="switchTab(this,'set-fees')">الرسوم</button>
        <button class="tab-btn" onclick="switchTab(this,'set-backup')">البيانات</button>
      </div>
      <div id="set-school">
        <div class="g2">
          <div class="card">
            <div class="card-head"><span class="card-title">🏫 بيانات المدرسة</span></div>
            <div class="card-body">
              <div class="form-row fr-2">
                <div class="form-group">
                  <label class="form-label">اسم المدرسة</label>
                  <input type="text" class="form-control" id="settSchoolName" placeholder="مدرسة نور القرآن">
                </div>
                <div class="form-group">
                  <label class="form-label">اسم المدير</label>
                  <input type="text" class="form-control" id="settAdminName" placeholder="اسم المدير">
                </div>
              </div>
              <div class="form-row fr-2">
                <div class="form-group">
                  <label class="form-label">رقم الهاتف</label>
                  <input type="tel" class="form-control" id="settPhone" dir="ltr">
                </div>
                <div class="form-group">
                  <label class="form-label">البريد الإلكتروني</label>
                  <input type="email" class="form-control" id="settEmail" dir="ltr">
                </div>
              </div>
              <div class="form-group" style="margin-bottom:14px">
                <label class="form-label">العنوان</label>
                <input type="text" class="form-control" id="settAddress">
              </div>
              <div class="form-row fr-2">
                <div class="form-group">
                  <label class="form-label">السنة الدراسية</label>
                  <input type="text" class="form-control" id="settYear" placeholder="1446-1447 هـ">
                </div>
                <div class="form-group">
                  <label class="form-label">المدينة</label>
                  <input type="text" class="form-control" id="settCity">
                </div>
              </div>
              <button class="btn btn-primary" onclick="saveSettings()">💾 حفظ البيانات</button>
            </div>
          </div>
          <div class="card">
            <div class="card-head"><span class="card-title">💳 إعدادات الرسوم</span></div>
            <div class="card-body">
              <div class="form-group" style="margin-bottom:12px">
                <label class="form-label">رسوم الاشتراك الشهرية (ريال)</label>
                <input type="number" class="form-control" id="settMonthlyFee" value="500">
              </div>
              <div class="form-group" style="margin-bottom:12px">
                <label class="form-label">رسوم التسجيل (ريال)</label>
                <input type="number" class="form-control" id="settRegFee" value="200">
              </div>
              <div class="form-group" style="margin-bottom:12px">
                <label class="form-label">غرامة التأخير (ريال)</label>
                <input type="number" class="form-control" id="settLateFee" value="50">
              </div>
              <button class="btn btn-primary" onclick="saveFeeSettings()">💾 حفظ</button>
            </div>
          </div>
        </div>
      </div>
      <div id="set-fees" style="display:none">
        <div class="card">
          <div class="card-head"><span class="card-title">💳 إعدادات الرسوم التفصيلية</span></div>
          <div class="card-body">
            <div class="alert alert-info">يمكن تحديد رسوم مختلفة لكل حلقة أو منح إعفاءات لأسر معينة</div>
            <div id="groupFeesList"></div>
          </div>
        </div>
      </div>
      <div id="set-backup" style="display:none">
        <div class="card">
          <div class="card-head"><span class="card-title">💾 إدارة البيانات</span></div>
          <div class="card-body">
            <div class="alert alert-warning">⚠️ يُنصح بعمل نسخة احتياطية بشكل دوري</div>
            <div class="btn-group">
              <button class="btn btn-primary" onclick="exportAllData()">📤 تصدير جميع البيانات (JSON)</button>
              <button class="btn btn-gold" onclick="document.getElementById('importFile').click()">📥 استيراد بيانات</button>
              <input type="file" id="importFile" style="display:none" accept=".json" onchange="importData(this)">
              <button class="btn btn-danger" onclick="resetDatabase()">🗑️ إعادة تهيئة النظام</button>
            </div>
            <div class="divider"></div>
            <div id="dbStats" style="margin-top:12px"></div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /content -->
</div><!-- /main -->

<!-- ==================== MODALS ==================== -->
<!-- Add Student -->
<div class="modal-bg" id="addStudentModal">
  <div class="modal modal-lg">
    <div class="modal-head">
      <span class="modal-title">➕ إضافة / تعديل طالب</span>
      <button class="modal-close" onclick="closeModal('addStudentModal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="editStudentId">
      <div class="form-row fr-3">
        <div class="form-group">
          <label class="form-label">الاسم الكامل *</label>
          <input type="text" class="form-control" id="stName" placeholder="اسم الطالب رباعياً">
        </div>
        <div class="form-group">
          <label class="form-label">تاريخ الميلاد</label>
          <input type="date" class="form-control" id="stDob">
        </div>
        <div class="form-group">
          <label class="form-label">رقم الهوية</label>
          <input type="text" class="form-control" id="stIdNum" placeholder="رقم الهوية" dir="ltr">
        </div>
      </div>
      <div class="form-row fr-3">
        <div class="form-group">
          <label class="form-label">اسم ولي الأمر *</label>
          <input type="text" class="form-control" id="stGuardian" placeholder="اسم ولي الأمر">
        </div>
        <div class="form-group">
          <label class="form-label">جوال ولي الأمر *</label>
          <input type="tel" class="form-control" id="stPhone" dir="ltr" placeholder="05xxxxxxxx">
        </div>
        <div class="form-group">
          <label class="form-label">جوال إضافي</label>
          <input type="tel" class="form-control" id="stPhone2" dir="ltr" placeholder="جوال آخر">
        </div>
      </div>
      <div class="form-row fr-3">
        <div class="form-group">
          <label class="form-label">الحلقة *</label>
          <select class="form-control" id="stGroup"></select>
        </div>
        <div class="form-group">
          <label class="form-label">مستوى الحفظ الحالي</label>
          <select class="form-control" id="stLevel">
            <option value="beginner">مبتدئ</option>
            <option value="medium">متوسط</option>
            <option value="advanced">متقدم</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">الأجزاء المحفوظة</label>
          <input type="number" class="form-control" id="stMemorized" min="0" max="30" placeholder="0">
        </div>
      </div>
      <div class="form-row fr-3">
        <div class="form-group">
          <label class="form-label">حالة الرسوم</label>
          <select class="form-control" id="stFeeStatus">
            <option value="normal">عادي</option>
            <option value="partial">إعفاء جزئي</option>
            <option value="full">إعفاء كامل</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">الرسوم الشهرية (ريال)</label>
          <input type="number" class="form-control" id="stFeeAmount" placeholder="500">
        </div>
        <div class="form-group">
          <label class="form-label">تاريخ التسجيل</label>
          <input type="date" class="form-control" id="stRegDate">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">ملاحظات</label>
        <textarea class="form-control" id="stNotes" rows="2" placeholder="أي ملاحظات خاصة..."></textarea>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-ghost" onclick="closeModal('addStudentModal')">إلغاء</button>
      <button class="btn btn-primary" onclick="saveStudent()">💾 حفظ الطالب</button>
    </div>
  </div>
</div>

<!-- Add Teacher -->
<div class="modal-bg" id="addTeacherModal">
  <div class="modal modal-lg">
    <div class="modal-head">
      <span class="modal-title">👨‍🏫 إضافة / تعديل معلم</span>
      <button class="modal-close" onclick="closeModal('addTeacherModal')">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="editTeacherId">
      <div class="form-row fr-3">
        <div class="form-group">
          <label class="form-label">الاسم الكامل *</label>
          <input type="text" class="form-control" id="tcName" placeholder="اسم المعلم">
        </div>
        <div class="form-group">
          <label class="form-label">رقم الجوال *</label>
          <input type="tel" class="form-control" id="tcPhone" dir="ltr">
        </div>
        <div class="form-group">
          <label class="form-label">رقم الهوية</label>
          <input type="text" class="form-control" id="tcId" dir="ltr">
        </div>
      </div>
      <div class="form-row fr-3">
        <div class="form-group">
          <label class="form-label">التخصص</label>
          <select class="form-control" id="tcSpec">
            <option value="hafz">تحفيظ القرآن الكريم</option>
            <option value="tajweed">التجويد والقراءات</option>
            <option value="both">التحفيظ والتجويد</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">المؤهل العلمي</label>
          <input type="text" class="form-control" id="tcQual" placeholder="إجازة في القرآن...">
        </div>
        <div class="form-group">
          <label class="form-label">سنوات الخبرة</label>
          <input type="number" class="form-control" id="tcExp" min="0" placeholder="5">
        </div>
      </div>
      <div class="form-row fr-3">
        <div class="form-group">
          <label class="form-label">الراتب الأساسي (ريال)</label>
          <input type="number" class="form-control" id="tcBaseSalary" placeholder="4000">
        </div>
        <div class="form-group">
          <label class="form-label">بدل سكن (ريال)</label>
          <input type="number" class="form-control" id="tcHousing" placeholder="1000">
        </div>
        <div class="form-group">
          <label class="form-label">بدل نقل (ريال)</label>
          <input type="number" class="form-control" id="tcTransport" placeholder="500">
        </div>
      </div>
      <div class="form-row fr-2">
        <div class="form-group">
          <label class="form-label">تاريخ التعيين</label>
          <input type="date" class="form-control" id="tcHireDate">
        </div>
        <div class="form-group">
          <label class="form-label">رقم الحساب البنكي (IBAN)</label>
          <input type="text" class="form-control" id="tcIban" dir="ltr" placeholder="SA...">
        </div>
      </div>
    </div>
    <div class="modal-foot">
