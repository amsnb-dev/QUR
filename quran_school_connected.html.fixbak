<!-- Toast -->
<div id="toast-container"></div>

<script>
// ==================== API LAYER ====================
const API = 'http://localhost:8080';
let _token = '';

async function apiCall(method, path, body) {
  const opts = { method, headers: { 'Content-Type': 'application/json' } };
  if (_token) opts.headers['Authorization'] = 'Bearer ' + _token;
  if (body !== undefined) opts.body = JSON.stringify(body);
  const res = await fetch(API + path, opts);
  if (res.status === 401) { showLoginScreen(); return null; }
  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(data.error || 'خطأ في الطلب');
  return data;
}

async function apiGet(path) { return apiCall('GET', path); }
async function apiPost(path, body) { return apiCall('POST', path, body); }
async function apiPut(path, body) { return apiCall('PUT', path, body); }
async function apiPatch(path, body) { return apiCall('PATCH', path, body || {}); }
async function apiDelete(path) { return apiCall('DELETE', path); }

// ==================== LOCAL CACHE ====================
// Pages that don't exist in API yet use localStorage as fallback
const LC = {
  get: (k) => { try { return JSON.parse(localStorage.getItem('qs_'+k)||'[]'); } catch(e){ return []; } },
  set: (k, v) => { try { localStorage.setItem('qs_'+k, JSON.stringify(v)); } catch(e){} },
  add: (k, v) => { const all = LC.get(k); const id = Date.now(); const item = {...v, id, createdAt:id}; all.push(item); LC.set(k,all); return id; },
  put: (k, v) => { const all = LC.get(k); const i = all.findIndex(x=>x.id===v.id); if(i>=0) all[i]={...all[i],...v,updatedAt:Date.now()}; else all.push(v); LC.set(k,all); },
  del: (k, id) => { const all = LC.get(k).filter(x=>x.id!==id); LC.set(k,all); },
  clear: (k) => { localStorage.removeItem('qs_'+k); },
};

// ==================== LOGIN ====================
function showLoginScreen() {
  _token = '';
  localStorage.removeItem('qs_token');
  document.getElementById('loginOverlay').style.display = 'flex';
}

async function doLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const pass = document.getElementById('loginPass').value;
  const btn = document.getElementById('loginBtn');
  const err = document.getElementById('loginErr');
  err.style.display = 'none';
  btn.disabled = true; btn.textContent = 'جاري التحقق...';
  try {
    const res = await fetch(API + '/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password: pass })
    });
    const data = await res.json();
    if (!res.ok) { err.style.display='block'; err.textContent = data.error||'بيانات غير صحيحة'; return; }
    _token = data.access_token;
    localStorage.setItem('qs_token', _token);
    localStorage.setItem('qs_rtoken', data.refresh_token||'');
    document.getElementById('loginOverlay').style.display = 'none';
    await afterLogin();
  } catch(e) {
    err.style.display='block'; err.textContent = 'تعذر الاتصال بالخادم';
  } finally { btn.disabled=false; btn.textContent='🔐 تسجيل الدخول'; }
}

async function afterLogin() {
  try {
    const me = await apiGet('/me');
    if (me) {
      document.getElementById('adminName').textContent = me.full_name || me.email || 'المدير';
    }
  } catch(e) {}
  await initApp();
}

async function doLogout() {
  try { await apiPost('/auth/logout', {}); } catch(e) {}
  _token = '';
  localStorage.removeItem('qs_token');
  localStorage.removeItem('qs_rtoken');
  showLoginScreen();
}

// ==================== API DATA FUNCTIONS ====================
// These replace all dbGetAll/dbAdd/dbPut/dbDelete calls

async function apiGetStudents(params='') {
  const r = await apiGet('/students?limit=200' + (params?'&'+params:''));
  return (r?.data || []).map(s => ({
    ...s,
    // map API fields to local field names used in UI
    name: s.full_name,
    dob: s.date_of_birth ? s.date_of_birth.split('T')[0] : '',
    guardian: s.guardian_name,
    memorized: s.memorized_parts || 0,
    feeAmount: s.monthly_fee || 0,
    feeStatus: s.fee_exemption === 'full' ? 'full' : s.fee_exemption === 'partial' ? 'partial' : 'normal',
    status: s.is_archived ? 'inactive' : 'active',
    regDate: s.enrollment_date ? s.enrollment_date.split('T')[0] : '',
    groupId: s._groupId || 0, // filled by enrichStudentsWithGroups
    createdAt: new Date(s.created_at).getTime()
  }));
}

async function apiGetGroups() {
  const r = await apiGet('/groups?limit=100');
  return (r?.data || []).map(g => ({
    ...g,
    name: g.name,
    startTime: g.start_time ? g.start_time.slice(0,5) : '',
    endTime: g.end_time ? g.end_time.slice(0,5) : '',
    days: Array.isArray(g.days) ? g.days : (g.days||'').split(' ').filter(Boolean).map(Number),
    capacity: g.capacity || 0,
    level: g.level || 'beginner',
    createdAt: new Date(g.created_at).getTime()
  }));
}

async function apiSaveStudent(data, id) {
  const body = {
    full_name: data.name,
    date_of_birth: data.dob ? new Date(data.dob + 'T00:00:00Z').toISOString() : new Date('2010-01-01').toISOString(),
    guardian_name: data.guardian || 'غير محدد',
    memorized_parts: Number(data.memorized || 0),
    monthly_fee: Number(data.feeAmount || 0),
    fee_exemption: data.feeStatus === 'full' ? 'full' : data.feeStatus === 'partial' ? 'partial' : 'none',
  };
  if (id) {
    await apiPut('/students/' + id, body);
    return id;
  } else {
    const r = await apiPost('/students', body);
    return r?.id;
  }
}

async function apiSaveGroup(data, id) {
  const body = {
    name: data.name,
    level: data.level || 'beginner',
    start_time: data.startTime || '07:00',
    end_time: data.endTime || '09:00',
    capacity: Number(data.capacity || 20),
    room: data.room || undefined,
    days: data.days && data.days.length ? data.days : [0,1,2,3,4],
    teacher_id: (() => {
  const sel = document.querySelector('#teacherSelect, #groupTeacherSelect, select[name="teacher_id"], select[name="teacherId"], select[data-field="teacher"]');
  const v = sel?.value ?? data.teacherId;
  const n = Number(v);
  return Number.isFinite(n) && n > 0 ? n : undefined;
})()
  };
    // normalize payload types/formats (safe)
  // prefer selected teacher from group modal if present
  const gpSel = document.getElementById('gpTeacher');
  if (gpSel && gpSel.value !== '' && Number.isFinite(Number(gpSel.value))) {
    body.teacher_id = Number(gpSel.value);
  } else if (body.teacher_id !== undefined && body.teacher_id !== null) {
    body.teacher_id = Number(body.teacher_id);
  }

  if (!Number.isFinite(body.teacher_id) || body.teacher_id <= 0) delete body.teacher_id;

  if (typeof body.start_time === "string" && body.start_time.length === 5) body.start_time = body.start_time + ":00";
  if (typeof body.end_time === "string" && body.end_time.length === 5) body.end_time = body.end_time + ":00";

  // support both field names
  if (Array.isArray(body.days) && body.days_of_week == null) body.days_of_week = body.days;
  if (Array.isArray(body.days_of_week) && body.days == null) body.days = body.days_of_week;

  if (!body.teacher_id) delete body.teacher_id;
  if (!body.room) delete body.room;
  if (id) {
    await apiPut('/groups/' + id, body);
    return id;
  } else {
    const r = await apiPost('/groups', body);
    return r?.id;
  }
}

async function apiGetStudentGroups(studentId) {
  try {
    const r = await apiGet('/students/' + studentId + '/groups');
    return r?.data || r || [];
  } catch(e) { return []; }
}

async function apiAddStudentToGroup(studentId, groupId) {
  return apiPost('/students/' + studentId + '/groups', {
    group_id: groupId,
    is_primary: true,
    start_date: new Date().toISOString()
  });
}

async function apiGetAttendance(groupId, date) {
  try {
    const r = await apiGet('/groups/' + groupId + '/attendance?date=' + date);
    return r?.data || [];
  } catch(e) { return []; }
}

async function apiSaveAttendance(groupId, date, items) {
  return apiPost('/groups/' + groupId + '/attendance', { date, items });
}

async function apiGetMemorization(studentId) {
  try {
    const r = await apiGet('/students/' + studentId + '/memorization?limit=50');
    return (r?.data || []).map(m => ({
      ...m,
      studentId: m.student_id,
      surahIdx: m.surah_number,
      surahName: SURAHS[m.surah_number - 1] || '',
      type: m.entry_type,
      grade: String(m.grade || 3),
      createdAt: new Date(m.created_at).getTime()
    }));
  } catch(e) { return []; }
}

async function apiSaveMemorization(studentId, data) {
  return apiPost('/students/' + studentId + '/memorization', {
    date: new Date().toISOString(),
    surah_number: Number(data.surahIdx),
    from_verse: Number(data.from || 1),
    to_verse: Number(data.to || 1),
    entry_type: data.type || 'new',
    grade: Number(data.grade || 3),
    group_id: data.groupId || undefined
  });
}

// ==================== UTILS ====================
function toast(msg, type='success') {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 3000);
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function showConfirm(title, msg, cb) {
  document.getElementById('confirmTitle').textContent = title;
  document.getElementById('confirmMsg').textContent = msg;
  document.getElementById('confirmBtn').onclick = () => { closeModal('confirmModal'); cb(); };
  openModal('confirmModal');
}

function formatDate(ts) {
  if (!ts) return '-';
  return new Date(ts).toLocaleDateString('ar-SA');
}

function formatMoney(n) {
  return Number(n||0).toLocaleString('ar-SA') + ' ريال';
}

function today() { return new Date().toISOString().split('T')[0]; }
function thisMonth() { return new Date().toISOString().slice(0,7); }

function age(dob) {
  if (!dob) return '-';
  const diff = Date.now() - new Date(dob).getTime();
  return Math.floor(diff / (1000*60*60*24*365.25));
}

function gradeLabel(g) {
  const m = {'5':'ممتاز','4':'جيد جداً','3':'جيد','2':'مقبول','1':'ضعيف'};
  return m[String(g)] || g;
}

function gradeBadge(g) {
  const m = {'5':'bg','4':'bg','3':'bb','2':'by','1':'br'};
  return `<span class="badge ${m[String(g)]||'bgr'}">${gradeLabel(g)}</span>`;
}

function statusBadge(s) {
  if (s==='active'||s===undefined) return '<span class="badge bg">نشط</span>';
  if (s==='inactive') return '<span class="badge br">موقوف</span>';
  return '<span class="badge bgr">'+s+'</span>';
}

function switchTab(btn, showId) {
  const parent = btn.closest('.tabs-wrap');
  parent.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const wrap = btn.closest('.page');
  if (!wrap) return;
  const allPanels = [];
  let sib = parent.nextElementSibling;
  while (sib) { if (sib.id) allPanels.push(sib); sib = sib.nextElementSibling; }
  allPanels.forEach(p => p.style.display = (p.id === showId) ? 'block' : 'none');
}

const DAYS = ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
const MONTHS_AR = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];

const SURAHS = [
  'الفاتحة','البقرة','آل عمران','النساء','المائدة','الأنعام','الأعراف','الأنفال','التوبة','يونس',
  'هود','يوسف','الرعد','إبراهيم','الحجر','النحل','الإسراء','الكهف','مريم','طه',
  'الأنبياء','الحج','المؤمنون','النور','الفرقان','الشعراء','النمل','القصص','العنكبوت','الروم',
  'لقمان','السجدة','الأحزاب','سبأ','فاطر','يس','الصافات','ص','الزمر','غافر',
  'فصلت','الشورى','الزخرف','الدخان','الجاثية','الأحقاف','محمد','الفتح','الحجرات','ق',
  'الذاريات','الطور','النجم','القمر','الرحمن','الواقعة','الحديد','المجادلة','الحشر','الممتحنة',
  'الصف','الجمعة','المنافقون','التغابن','الطلاق','التحريم','الملك','القلم','الحاقة','المعارج',
  'نوح','الجن','المزمل','المدثر','القيامة','الإنسان','المرسلات','النبأ','النازعات','عبس',
  'التكوير','الانفطار','المطففين','الانشقاق','البروج','الطارق','الأعلى','الغاشية','الفجر','البلد',
  'الشمس','الليل','الضحى','الشرح','التين','العلق','القدر','البينة','الزلزلة','العاديات',
  'القارعة','التكاثر','العصر','الهمزة','الفيل','قريش','الماعون','الكوثر','الكافرون','النصر',
  'المسد','الإخلاص','الفلق','الناس'
];

const EXP_CATS = {utilities:'كهرباء وماء',supplies:'لوازم مكتبية',maintenance:'صيانة',books:'كتب ومطبوعات',events:'فعاليات وأنشطة',other:'أخرى'};
const FEE_METHODS = {cash:'نقداً',transfer:'تحويل بنكي',card:'بطاقة',app:'تطبيق دفع'};
const PAY_METHODS = {cash:'نقداً',transfer:'تحويل',card:'بطاقة'};
const LEVEL_LABELS = {beginner:'مبتدئ',medium:'متوسط',advanced:'متقدم',mixed:'مختلط'};
const SPEC_LABELS = {hafz:'تحفيظ',tajweed:'تجويد',both:'تحفيظ وتجويد'};
const REC_TYPES = {hafz:'حفظ جديد',muraja:'مراجعة',tajweed:'تجويد',exam:'اختبار'};

// ==================== NAVIGATION ====================
let currentPage = 'dashboard';

function navigate(page) {
  document.querySelectorAll('.nav-link').forEach(n => n.classList.remove('active'));
  document.querySelector(`[data-page="${page}"]`)?.classList.add('active');
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const pg = document.getElementById('page-'+page);
  if (pg) pg.classList.add('active');
  currentPage = page;
  const titles = {
    dashboard:'لوحة التحكم',students:'إدارة الطلاب',attendance:'الحضور والغياب',
    memorization:'متابعة الحفظ',recitation:'التسميع والتجويد',exams:'الاختبارات',
    teachers:'المعلمون',groups:'الحلقات والمجموعات',schedule:'الجدول الدراسي',
    fees:'رسوم الطلاب',payroll:'الرواتب والأجور',expenses:'المصروفات',
    reports:'التقارير والإحصاء',notifications:'الإشعارات',settings:'إعدادات النظام'
  };
  document.getElementById('pageTitle').textContent = titles[page]||page;
  loadPage(page);
}

document.getElementById('sidebarNav').addEventListener('click', e => {
  const link = e.target.closest('.nav-link');
  if (link) { navigate(link.dataset.page); closeSidebar(); }
});

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('open');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('open');
}

document.querySelectorAll('.modal-bg').forEach(bg => {
  bg.addEventListener('click', e => { if (e.target===bg) bg.classList.remove('open'); });
});
document.addEventListener('keydown', e => {
  if (e.key==='Escape') document.querySelectorAll('.modal-bg.open').forEach(m => m.classList.remove('open'));
});

// ==================== PAGE LOADER ====================
async function loadPage(page) {
  switch(page) {
    case 'dashboard': await loadDashboard(); break;
    case 'students': await loadStudents(); break;
    case 'attendance': await loadAttendancePage(); break;
    case 'memorization': await loadMemorizationPage(); break;
    case 'recitation': await loadRecitationPage(); break;
    case 'exams': await loadExams(); break;
    case 'teachers': await loadTeachers(); break;
    case 'groups': await loadGroups(); break;
    case 'schedule': await loadSchedule(); break;
    case 'fees': await loadFees(); break;
    case 'payroll': await loadPayroll(); break;
    case 'expenses': await loadExpenses(); break;
    case 'reports': await loadReports(); break;
    case 'notifications': await loadNotifications(); break;
    case 'settings': await loadSettings(); break;
  }
}

// ==================== DASHBOARD ====================
async function loadDashboard() {
  const [students, groups] = await Promise.all([apiGetStudents(), apiGetGroups()]);
  const activeStudents = students.filter(s => s.status === 'active');
  const activeTeachers = LC.get('teachers').filter(t => t.status !== 'inactive');
  const graduates = students.filter(s => Number(s.memorized) >= 30).length;
  const allFees = LC.get('fees');
  const totalFees = allFees.reduce((a,f) => a + Number(f.amount||0), 0);

  // Try to get today's attendance from API
  let presentToday = 0;
  const todayStr = today();
  for (const g of groups.slice(0,5)) {
    try {
      const att = await apiGetAttendance(g.id, todayStr);
      presentToday += att.filter(a => a.status === 'present').length;
    } catch(e) {}
  }

  document.getElementById('dashStats').innerHTML = `
    <div class="stat-card green"><div class="stat-icon-wrap si-green">🎓</div><div class="stat-body"><div class="stat-val">${activeStudents.length}</div><div class="stat-lbl">إجمالي الطلاب</div><div class="stat-chg chg-up">↑ نشطون</div></div></div>
    <div class="stat-card gold"><div class="stat-icon-wrap si-gold">👨‍🏫</div><div class="stat-body"><div class="stat-val">${activeTeachers.length}</div><div class="stat-lbl">المعلمون النشطون</div><div class="stat-chg chg-up">${groups.length} حلقة</div></div></div>
    <div class="stat-card blue"><div class="stat-icon-wrap si-blue">✅</div><div class="stat-body"><div class="stat-val">${presentToday}</div><div class="stat-lbl">حاضرون اليوم</div><div class="stat-chg ${presentToday>0?'chg-up':'chg-dn'}">من ${activeStudents.length} طالب</div></div></div>
    <div class="stat-card red"><div class="stat-icon-wrap si-purple">🏆</div><div class="stat-body"><div class="stat-val">${graduates}</div><div class="stat-lbl">حفّاظ القرآن</div><div class="stat-chg chg-up">${formatMoney(totalFees)} محصّل</div></div></div>
  `;

  // Attendance chart (last 7 days)
  const chartDays = [];
  for(let i=6;i>=0;i--) {
    const d = new Date(); d.setDate(d.getDate()-i);
    const ds = d.toISOString().split('T')[0];
    chartDays.push({day:DAYS[d.getDay()].slice(0,3), pct:0, ds});
  }
  const maxPct = 100;
  document.getElementById('attendanceChart').innerHTML = chartDays.map(d=>`
    <div class="bar-item" style="position:relative">
      <span style="font-size:10px;font-weight:700;color:var(--g2);position:absolute;top:-16px">${d.pct>0?d.pct+'%':''}</span>
      <div class="bar prog-green" style="height:${Math.max((d.pct/maxPct)*140,4)}px"></div>
      <span style="font-size:10px;color:var(--text3);margin-top:4px">${d.day}</span>
    </div>
  `).join('');
  document.getElementById('avgAttBadge').textContent = '—';

  // Top students
  const sorted = [...students].sort((a,b)=>Number(b.memorized)-Number(a.memorized)).slice(0,5);
  document.querySelector('#topStudentsTable tbody').innerHTML = sorted.map((s,i)=>`
    <tr><td>${i+1}</td><td class="td-name">${s.name||'-'}</td>
    <td><span class="badge bg">${s.memorized||0}/30 جزء</span></td>
    <td>—</td><td>${gradeBadge('4')}</td></tr>
  `).join('') || '<tr><td colspan="5"><div class="empty"><p>لا يوجد طلاب</p></div></td></tr>';

  // Memorization progress
  const total = students.length || 1;
  const avgMem = students.reduce((a,s)=>a+Number(s.memorized||0),0) / total;
  const pct = Math.round((avgMem/30)*100);
  document.getElementById('memorizationProgress').innerHTML = `
    <div style="text-align:center;padding:16px 0">
      <div style="font-size:42px;font-weight:800;color:var(--g1)">${pct}%</div>
      <div style="font-size:13px;color:var(--text3);margin-bottom:14px">متوسط تقدم الحفظ</div>
      <div class="prog-wrap" style="height:14px"><div class="prog-fill prog-green" style="width:${pct}%"></div></div>
      <div style="font-size:12px;color:var(--text3);margin-top:8px">متوسط ${avgMem.toFixed(1)} جزء من 30</div>
    </div>
    <div class="summary-box">
      <div><div class="summary-val" style="color:var(--g2)">${students.filter(s=>Number(s.memorized)>=30).length}</div><div class="summary-lbl">ختموا القرآن</div></div>
      <div><div class="summary-val" style="color:var(--gold2)">${students.filter(s=>Number(s.memorized)>=15).length}</div><div class="summary-lbl">أكثر من نصف</div></div>
      <div><div class="summary-val" style="color:var(--blue2)">${students.filter(s=>Number(s.memorized)<5).length}</div><div class="summary-lbl">في البداية</div></div>
    </div>
  `;

  // Notifications
  const notifs = LC.get('notifications').sort((a,b)=>b.createdAt-a.createdAt).slice(0,3);
  document.getElementById('dashNotifCount').textContent = LC.get('notifications').filter(n=>!n.read).length;
  document.getElementById('dashNotifications').innerHTML = notifs.map(n=>`
    <div style="display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--border)">
      <span style="font-size:20px">${n.icon||'📢'}</span>
      <div><div style="font-size:13px;font-weight:700">${n.title}</div><div style="font-size:12px;color:var(--text2)">${n.text}</div></div>
    </div>
  `).join('') || '<div class="empty" style="padding:20px"><p>لا توجد إشعارات</p></div>';
}

// ==================== STUDENTS ====================
let _studentsCache = [];

async function loadStudents() {
  _studentsCache = await apiGetStudents();
  document.getElementById('filterGroup') && await populateGroupSelect('filterGroup');
  renderStudentsTable(_studentsCache, await apiGetGroups());
}

function renderStudentsTable(students, groups) {
  const gMap = {};
  (groups||[]).forEach(g => gMap[g.id] = g.name);
  const search = (document.getElementById('studentSearch')?.value||'').toLowerCase();
  const gFilter = document.getElementById('filterGroup')?.value||'';
  const sFilter = document.getElementById('filterStatus')?.value||'';
  let filtered = students.filter(s => {
    const matchSearch = !search || (s.name||'').toLowerCase().includes(search);
    const matchStatus = !sFilter || s.status===sFilter;
    return matchSearch && matchStatus;
  });
  document.getElementById('studentsCount').textContent = filtered.length + ' طالب';
  const tbody = document.querySelector('#studentsTable tbody');
  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="9"><div class="empty"><div class="empty-icon">👨‍🎓</div><p>لا يوجد طلاب</p></div></td></tr>';
    return;
  }
  tbody.innerHTML = filtered.map((s,i)=>`
    <tr>
      <td>${i+1}</td>
      <td class="td-name" style="cursor:pointer" onclick="viewStudent('${s.id}')">${s.name||'-'}</td>
      <td>${age(s.dob)||'-'} سنة</td>
      <td>${gMap[s.groupId]||'—'}</td>
      <td><div class="prog-wrap" style="width:80px"><div class="prog-fill prog-green" style="width:${Math.min(Number(s.memorized||0)/30*100,100)}%"></div></div><span style="font-size:11px;color:var(--text3)">${s.memorized||0}/30</span></td>
      <td>—</td>
      <td>${s.feeStatus==='full'?'<span class="badge bg">معفى</span>':s.feeStatus==='partial'?'<span class="badge by">جزئي</span>':formatMoney(s.feeAmount)}</td>
      <td>${statusBadge(s.status)}</td>
      <td><div class="row-actions">
        <button class="btn btn-xs btn-outline" onclick="viewStudent('${s.id}')">👁️</button>
        <button class="btn btn-xs btn-primary" onclick="editStudent('${s.id}')">✏️</button>
        <button class="btn btn-xs btn-danger" onclick="archiveStudent('${s.id}','${(s.name||'').replace(/'/g,"\\'")}')">🗑️</button>
      </div></td>
    </tr>
  `).join('');
}

function filterStudents() { renderStudentsTable(_studentsCache, []); }

async function viewStudent(id) {
  const s = _studentsCache.find(x => x.id === id);
  if (!s) return;
  const groups = await apiGetGroups();
  const gMap = {};
  groups.forEach(g => gMap[g.id] = g.name);
  const memRecs = await apiGetMemorization(id);
  const pct = Math.min(Math.round(Number(s.memorized||0)/30*100),100);
  document.getElementById('profileModalTitle').textContent = 'ملف الطالب: ' + s.name;
  document.getElementById('studentProfileContent').innerHTML = `
    <div style="display:flex;gap:18px;margin-bottom:20px;padding:18px;background:linear-gradient(135deg,#f0f7f3,var(--cream));border-radius:14px;align-items:center">
      <div class="av av-green" style="width:68px;height:68px;font-size:32px;box-shadow:0 6px 18px rgba(13,92,58,.2)">👦</div>
      <div style="flex:1">
        <div style="font-size:20px;font-weight:800;margin-bottom:4px">${s.name}</div>
        <div style="font-size:13px;color:var(--text3);margin-bottom:8px">تسجيل: ${formatDate(new Date(s.regDate).getTime())}</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">${statusBadge(s.status)}<span class="badge bb">${LEVEL_LABELS[s.level]||'مبتدئ'}</span>${Number(s.memorized)>=30?'<span class="badge bg">حافظ للقرآن كاملاً 🏆</span>':''}</div>
      </div>
    </div>
    <div class="g2" style="margin-bottom:16px">
      <div class="info-row">
        <div class="info-item"><div class="lbl">ولي الأمر</div><div class="val">${s.guardian||'-'}</div></div>
      </div>
      <div class="info-row">
        <div class="info-item"><div class="lbl">العمر</div><div class="val">${age(s.dob)||'-'} سنة</div></div>
      </div>
    </div>
    <div class="summary-box" style="margin-bottom:16px">
      <div><div class="summary-val" style="color:var(--g2)">${s.memorized||0}/30</div><div class="summary-lbl">جزء محفوظ</div></div>
      <div><div class="summary-val" style="color:var(--gold2)">—</div><div class="summary-lbl">نسبة الحضور</div></div>
      <div><div class="summary-val" style="color:var(--blue2)">${formatMoney(s.feeAmount)}</div><div class="summary-lbl">الرسوم الشهرية</div></div>
    </div>
    <div style="margin-bottom:14px">
      <div style="font-size:13px;font-weight:700;margin-bottom:8px;color:var(--g1)">تقدم الحفظ</div>
      <div class="prog-wrap" style="height:14px"><div class="prog-fill prog-green" style="width:${pct}%"></div></div>
      <div style="font-size:11px;color:var(--text3);margin-top:4px;text-align:center">${s.memorized||0} جزء من 30 • ${pct}%</div>
    </div>
    <div>
      <div style="font-size:13px;font-weight:700;margin-bottom:8px;color:var(--g1)">آخر سجلات الحفظ</div>
      ${memRecs.slice(0,5).map(r=>`<div style="display:flex;align-items:center;gap:10px;padding:8px;background:var(--cream);border-radius:8px;margin-bottom:6px">
        <span class="badge ${r.type==='new'?'bg':'by'}">${r.type==='new'?'جديد':'مراجعة'}</span>
        <span style="font-size:13px;flex:1">${r.surahName} (${r.surahIdx})</span>
        ${gradeBadge(r.grade)}
        <span style="font-size:11px;color:var(--text3)">${r.date||formatDate(r.createdAt)}</span>
      </div>`).join('') || '<p style="color:var(--text3);font-size:13px">لا يوجد سجل حفظ</p>'}
    </div>
  `;
  document.getElementById('profileEditBtn').onclick = ()=>{ closeModal('studentProfileModal'); editStudent(id); };
  openModal('studentProfileModal');
}

async function editStudent(id) {
  const s = _studentsCache.find(x => x.id === id);
  if (!s) return;
  document.getElementById('editStudentId').value = s.id;
  document.getElementById('stName').value = s.name||'';
  document.getElementById('stDob').value = s.dob||'';
  document.getElementById('stIdNum').value = s.idNum||'';
  document.getElementById('stGuardian').value = s.guardian||'';
  document.getElementById('stPhone').value = s.phone||'';
  document.getElementById('stPhone2').value = s.phone2||'';
  document.getElementById('stMemorized').value = s.memorized||0;
  document.getElementById('stFeeAmount').value = s.feeAmount||0;
  document.getElementById('stNotes').value = s.notes||'';
  document.getElementById('stRegDate').value = s.regDate||today();
  await populateGroupSelect('stGroup');
  document.getElementById('stGroup').value = s.groupId||'';
  document.getElementById('stLevel').value = s.level||'beginner';
  document.getElementById('stFeeStatus').value = s.feeStatus||'normal';
  openModal('addStudentModal');
}

async function saveStudent() {
  const id = document.getElementById('editStudentId').value;
  const name = document.getElementById('stName').value.trim();
  const groupId = document.getElementById('stGroup').value;
  if (!name) { toast('الاسم مطلوب','error'); return; }
  const data = {
    name, dob:document.getElementById('stDob').value,
    idNum:document.getElementById('stIdNum').value,
    guardian:document.getElementById('stGuardian').value.trim(),
    phone:document.getElementById('stPhone').value.trim(),
    phone2:document.getElementById('stPhone2').value.trim(),
    groupId: groupId || '',
    level:document.getElementById('stLevel').value,
    memorized:Number(document.getElementById('stMemorized').value)||0,
    feeStatus:document.getElementById('stFeeStatus').value,
    feeAmount:Number(document.getElementById('stFeeAmount').value)||0,
    regDate:document.getElementById('stRegDate').value||today(),
    notes:document.getElementById('stNotes').value,
  };
  try {
    const savedId = await apiSaveStudent(data, id||null);
    if (!id && groupId && savedId) {
      try { await apiAddStudentToGroup(savedId, groupId); } catch(e) {}
    }
    if (id) { toast('✅ تم تحديث بيانات الطالب'); }
    else { toast('✅ تم إضافة الطالب بنجاح'); addNotification('🎓','طالب جديد','تم تسجيل الطالب '+data.name); }
    closeModal('addStudentModal');
    clearStudentForm();
    _studentsCache = await apiGetStudents();
    if (currentPage==='students') loadStudents();
    if (currentPage==='dashboard') loadDashboard();
  } catch(e) { toast(e.message||'حدث خطأ','error'); }
}

function clearStudentForm() {
  ['editStudentId','stName','stDob','stIdNum','stGuardian','stPhone','stPhone2','stMemorized','stFeeAmount','stNotes'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  ['stGroup','stLevel','stFeeStatus'].forEach(id=>{const el=document.getElementById(id);if(el)el.selectedIndex=0;});
  document.getElementById('stRegDate').value = today();
}

async function archiveStudent(id, name) {
  showConfirm('أرشفة طالب','هل تريد أرشفة الطالب "'+name+'"؟\nلن يمكن رؤيته في القوائم النشطة.', async()=>{
    try {
      await apiPatch('/students/'+id+'/archive');
      toast('🗂️ تم أرشفة الطالب','warning');
      _studentsCache = await apiGetStudents();
      loadStudents();
    } catch(e) { toast(e.message||'حدث خطأ','error'); }
  });
}

async function exportStudents() {
  const students = _studentsCache;
  const rows = [['#','الاسم','ولي الأمر','الجوال','المحفوظ','الحالة']];
  students.forEach((s,i) => rows.push([i+1,s.name,s.guardian||'-',s.phone||'-',s.memorized||0,s.status||'active']));
  downloadCSV(rows, 'students.csv');
}

function downloadCSV(rows, filename) {
  const csv = rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=filename; a.click();
  toast('📤 تم تصدير الملف');
}

// ==================== ATTENDANCE ====================
async function loadAttendancePage() {
  const groups = await apiGetGroups();
  const students = await apiGetStudents();
  const attGroup = document.getElementById('attGroup');
  attGroup.innerHTML = groups.map(g=>`<option value="${g.id}">${g.name}</option>`).join('');
  document.getElementById('attDate').value = today();

  const sel = document.getElementById('attStudentSelect');
  sel.innerHTML = students.map(s=>`<option value="${s.id}">${s.name}</option>`).join('');
  document.getElementById('attMonth').value = thisMonth();

  await loadAttendanceStudents();
  await loadDailyAttTable();
}

async function loadAttendanceStudents() {
  const gId = document.getElementById('attGroup').value;
  const date = document.getElementById('attDate').value;
  if (!gId) return;

  const [students, existing] = await Promise.all([
    apiGetStudents(),
    apiGetAttendance(gId, date)
  ]);

  // Filter students in this group
  let grouped = [];
  for (const s of students.filter(s => s.status === 'active')) {
    const sGroups = await apiGetStudentGroups(s.id);
    const inGroup = sGroups.some(sg => sg.group_id === gId && sg.is_active !== false);
    if (inGroup) grouped.push(s);
  }

  const todayRec = {};
  existing.forEach(a => todayRec[a.student_id] = a);

  if (!grouped.length) {
    document.getElementById('attStudentsList').innerHTML = '<div class="empty"><p>لا يوجد طلاب في هذه الحلقة</p></div>';
    return;
  }

  document.getElementById('attStudentsList').innerHTML = `
    <div style="max-height:300px;overflow-y:auto;border:1px solid var(--border);border-radius:10px">
      <table style="width:100%">
        <thead><tr><th>الطالب</th><th>الحضور</th><th>ملاحظة</th></tr></thead>
        <tbody>${grouped.map(s=>{
          const rec = todayRec[s.id];
          return `<tr>
            <td class="td-name">${s.name}</td>
            <td>
              <div style="display:flex;gap:4px">
                <button class="btn btn-xs ${!rec||rec.status==='present'?'btn-primary':'btn-ghost'}" onclick="setAttBtn(this,'present','${s.id}')" data-student="${s.id}" data-status="present">✅</button>
                <button class="btn btn-xs ${rec?.status==='absent'?'btn-danger':'btn-ghost'}" onclick="setAttBtn(this,'absent','${s.id}')" data-student="${s.id}" data-status="absent">❌</button>
                <button class="btn btn-xs ${rec?.status==='excused'?'btn-gold':'btn-ghost'}" onclick="setAttBtn(this,'excused','${s.id}')" data-student="${s.id}" data-status="excused">📝</button>
                <button class="btn btn-xs ${rec?.status==='late'?'btn-outline':'btn-ghost'}" onclick="setAttBtn(this,'late','${s.id}')" data-student="${s.id}" data-status="late">⏰</button>
              </div>
            </td>
            <td><input type="text" class="form-control" style="padding:4px 8px" id="att-note-${s.id}" value="${rec?.note||''}" placeholder="ملاحظة"></td>
          </tr>`;
        }).join('')}</tbody>
      </table>
    </div>
  `;
}

function setAttBtn(btn, status, studentId) {
  const row = btn.closest('tr');
  row.querySelectorAll('.btn').forEach(b => {
    b.className = b.className.replace(/btn-primary|btn-danger|btn-gold|btn-outline/g,'btn-ghost');
  });
  const colors = {present:'btn-primary',absent:'btn-danger',excused:'btn-gold',late:'btn-outline'};
  btn.className = btn.className.replace('btn-ghost', colors[status]||'btn-primary');
  btn.dataset.selected = 'true';
}

async function saveAttendance() {
  const gId = document.getElementById('attGroup').value;
  const date = document.getElementById('attDate').value;
  if (!date) { toast('اختر التاريخ','error'); return; }

  const students = await apiGetStudents();
  let grouped = [];
  for (const s of students.filter(s=>s.status==='active')) {
    const sGroups = await apiGetStudentGroups(s.id);
    if (sGroups.some(sg=>sg.group_id===gId&&sg.is_active!==false)) grouped.push(s);
  }

  const items = grouped.map(s => {
    const selectedBtn = document.querySelector(`[data-student="${s.id}"][data-selected="true"]`);
    return { student_id: s.id, status: selectedBtn ? selectedBtn.dataset.status : 'present' };
  });

  try {
    await apiSaveAttendance(gId, date, items);
    toast('✅ تم حفظ الحضور بنجاح');
    const absents = items.filter(i=>i.status==='absent');
    if (absents.length>0) addNotification('⚠️','غياب طلاب',`${absents.length} طالب غائب اليوم`);
    await loadDailyAttTable();
  } catch(e) { toast(e.message||'خطأ في الحفظ','error'); }
}

async function loadStudentCalendar() {
  const studentId = document.getElementById('attStudentSelect').value;
  const month = document.getElementById('attMonth').value;
  if (!studentId||!month) return;
  const [year, m] = month.split('-').map(Number);
  const first = new Date(year, m-1, 1);
  const last = new Date(year, m, 0);

  // Get from API — try getting attendance for groups
  const groups = await apiGetGroups();
  const studentRec = {};
  for (const g of groups) {
    for (let d=1; d<=last.getDate(); d++) {
      const ds = `${year}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      try {
        const att = await apiGetAttendance(g.id, ds);
        const rec = att.find(a=>a.student_id===studentId);
        if (rec) studentRec[String(d)] = rec.status;
      } catch(e) {}
    }
    break; // only first group for performance
  }

  let cal = '<div class="cal-grid">';
  ['الأحد','الاثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'].forEach(d=>cal+=`<div class="cal-head">${d.slice(0,3)}</div>`);
  for(let i=0;i<first.getDay();i++) cal+=`<div class="cal-day cal-off"></div>`;
  for(let d=1;d<=last.getDate();d++) {
    const dd=String(d).padStart(2,'0');
    const dow=new Date(year,m-1,d).getDay();
    const st=studentRec[String(d)];
    const cls=dow===5||dow===6?'cal-off':!st?'':('cal-'+({'present':'present','absent':'absent','excused':'excused','late':'excused'}[st]||'off'));
    const todayCls=new Date().toISOString().slice(0,10)===`${year}-${String(m).padStart(2,'0')}-${dd}`?' cal-today':'';
    cal+=`<div class="cal-day ${cls}${todayCls}">${d}</div>`;
  }
  cal+='</div>';
  document.getElementById('studentCalendar').innerHTML = cal;

  const vals = Object.values(studentRec);
  const present=vals.filter(v=>v==='present').length;
  const absent=vals.filter(v=>v==='absent').length;
  const excused=vals.filter(v=>v==='excused').length;
  document.getElementById('attSummary').innerHTML = `<div class="summary-box">
    <div><div class="summary-val" style="color:#16a34a">${present}</div><div class="summary-lbl">حاضر</div></div>
    <div><div class="summary-val" style="color:var(--red2)">${absent}</div><div class="summary-lbl">غائب</div></div>
    <div><div class="summary-val" style="color:var(--gold2)">${excused}</div><div class="summary-lbl">بعذر</div></div>
  </div>`;
}

async function loadDailyAttTable() {
  const groups = await apiGetGroups();
  const students = await apiGetStudents();
  const sMap = {};
  students.forEach(s=>sMap[s.id]=s.name);
  const gMap = {};
  groups.forEach(g=>gMap[g.id]=g.name);
  const t = today();
  const rows = [];
  for (const g of groups) {
    try {
      const att = await apiGetAttendance(g.id, t);
      att.forEach(a => rows.push({...a, groupName:gMap[g.id]||'-', studentName:sMap[a.student_id]||a.student_id}));
    } catch(e) {}
  }
  const tbody = document.querySelector('#dailyAttTable tbody');
  tbody.innerHTML = rows.map(a=>{
    const sBadge = a.status==='present'?'<span class="badge bg">حاضر</span>':a.status==='absent'?'<span class="badge br">غائب</span>':a.status==='excused'?'<span class="badge by">بعذر</span>':'<span class="badge bgr">متأخر</span>';
    return `<tr><td class="td-name">${a.studentName}</td><td>${a.groupName}</td><td>${a.date?.split('T')[0]||t}</td><td>${sBadge}</td><td>${a.note||'-'}</td></tr>`;
  }).join('') || `<tr><td colspan="5"><div class="empty"><p>لا يوجد سجل حضور لهذا اليوم</p></div></td></tr>`;
}

// ==================== MEMORIZATION ====================
const SURAH_DATA = SURAHS.map((name,i)=>({name,num:i+1,juz:Math.ceil((i+1)/114*30)||1}));

async function loadMemorizationPage() {
  const students = await apiGetStudents();
  const sel = document.getElementById('memStudent');
  sel.innerHTML = '<option value="">-- اختر طالباً --</option>'+students.map(s=>`<option value="${s.id}">${s.name}</option>`).join('');
  const surahSel = document.getElementById('memSurah');
  surahSel.innerHTML = SURAHS.map((n,i)=>`<option value="${i+1}">${n}</option>`).join('');
  const juzSel = document.getElementById('memJuz');
  juzSel.innerHTML = '<option value="">-- الجزء --</option>'+Array.from({length:30},(_,i)=>`<option value="${i+1}">الجزء ${i+1}</option>`).join('');
  await loadMemLog();
}

async function loadStudentProgress() {
  const id = document.getElementById('memStudent').value;
  if (!id) { document.getElementById('studentProgressMap').innerHTML='<div class="empty"><div class="empty-icon">📖</div><p>اختر طالباً لعرض تقدمه</p></div>'; return; }
  const s = _studentsCache.find(x=>x.id===id) || (await apiGetStudents()).find(x=>x.id===id);
  if (!s) return;
  const records = await apiGetMemorization(id);
  const memorizedJuz = new Set(records.filter(r=>r.type==='new').map(r=>r.juz).filter(Boolean));
  const pct = Math.round((Number(s.memorized||0)/30)*100);
  let mapHtml = `
    <div style="text-align:center;padding:12px 0 16px;background:linear-gradient(135deg,var(--g1),var(--g2));border-radius:12px;margin-bottom:14px">
      <div style="font-size:30px;font-weight:800;color:#fff">${s.memorized||0} / 30</div>
      <div style="font-size:12px;color:rgba(255,255,255,.7)">جزء محفوظ • ${pct}%</div>
      <div style="margin:10px 16px 0"><div style="height:8px;background:rgba(255,255,255,.2);border-radius:4px"><div style="height:100%;width:${pct}%;background:var(--gold3);border-radius:4px"></div></div></div>
    </div>
    <div class="quran-grid">`;
  for(let j=1;j<=30;j++) {
    const done = memorizedJuz.has(j) || j<=Number(s.memorized||0);
    mapHtml+=`<div class="juz-item ${done?'juz-done':'juz-none'}"><div class="juz-num">${j}</div><div class="juz-lbl">ج${j}</div></div>`;
  }
  mapHtml+='</div>';
  document.getElementById('studentProgressMap').innerHTML = mapHtml;
}

async function saveMemorization() {
  const studentId = document.getElementById('memStudent').value;
  if (!studentId) { toast('اختر الطالب','error'); return; }
  const surahIdx = Number(document.getElementById('memSurah').value);
  const juz = Number(document.getElementById('memJuz').value)||0;
  const from = Number(document.getElementById('memFrom').value)||1;
  const to = Number(document.getElementById('memTo').value)||from;
  const type = document.getElementById('memType').value;
  const grade = document.getElementById('memGrade').value;
  const notes = document.getElementById('memNotes').value;

  // Get current group for student
  const sGroups = await apiGetStudentGroups(studentId);
  const groupId = sGroups[0]?.group_id || undefined;

  try {
    await apiSaveMemorization(studentId, { surahIdx, juz, from, to, type, grade, notes, groupId });
    toast('✅ تم تسجيل الحفظ');
    _studentsCache = await apiGetStudents();
    await loadStudentProgress();
    await loadMemLog();
    document.getElementById('memNotes').value='';
    document.getElementById('memFrom').value='';
    document.getElementById('memTo').value='';
  } catch(e) { toast(e.message||'خطأ','error'); }
}

async function loadMemLog() {
  const students = await apiGetStudents();
  const sMap={};
  students.forEach(s=>sMap[s.id]=s.name);
  const tbody = document.querySelector('#memLogTable tbody');
  const allRecs = [];
  for (const s of students.slice(0,30)) {
    const recs = await apiGetMemorization(s.id);
    recs.forEach(r => allRecs.push({...r, sName:sMap[s.id]||'-'}));
  }
  const recent = allRecs.sort((a,b)=>b.createdAt-a.createdAt).slice(0,15);
  tbody.innerHTML = recent.map(r=>`
    <tr><td>${r.date||formatDate(r.createdAt)}</td><td class="td-name">${r.sName||'-'}</td>
    <td>${r.surahName||SURAHS[r.surahIdx-1]||'-'} ${r.juz?'(ج'+r.juz+')':''}</td>
    <td><span class="badge ${r.type==='new'?'bg':'by'}">${r.type==='new'?'جديد':'مراجعة'}</span></td>
    <td>${gradeBadge(r.grade)}</td></tr>
  `).join('') || '<tr><td colspan="5"><div class="empty"><p>لا يوجد سجل حفظ</p></div></td></tr>';
}

// ==================== RECITATION ====================
async function loadRecitationPage() {
  const students = await apiGetStudents();
  ['recStudent','recSurah'].forEach(id => {
    const el = document.getElementById(id);
    if (id==='recStudent') el.innerHTML='<option value="">-- طالب --</option>'+students.map(s=>`<option value="${s.id}">${s.name}</option>`).join('');
    if (id==='recSurah') el.innerHTML=SURAHS.map((n,i)=>`<option value="${i+1}">${n}</option>`).join('');
  });
  await loadRecLog();
}

async function saveRecitation() {
  const studentId = document.getElementById('recStudent').value;
  if (!studentId) { toast('اختر الطالب','error'); return; }
  const data = {
    studentId, type:document.getElementById('recType').value,
    surahIdx:Number(document.getElementById('recSurah').value),
    surahName:SURAHS[Number(document.getElementById('recSurah').value)-1]||'',
    pages:document.getElementById('recPages').value,
    tajweedScore:Number(document.getElementById('recTajweedScore').value)||10,
    hafzScore:Number(document.getElementById('recHafzScore').value)||10,
    errors:[...document.querySelectorAll('#page-recitation input[type=checkbox]:checked')].map(c=>c.value),
    notes:document.getElementById('recNotes').value,
    date:today()
  };
  LC.add('recitation', data);
  toast('✅ تم حفظ جلسة التسميع');
  document.getElementById('recNotes').value='';
  document.getElementById('recPages').value='';
  document.getElementById('recTajweedScore').value='';
  document.getElementById('recHafzScore').value='';
  document.querySelectorAll('#page-recitation input[type=checkbox]').forEach(c=>c.checked=false);
  await loadRecLog();
}

async function loadRecLog() {
  const records = LC.get('recitation');
  const students = await apiGetStudents();
  const sMap={};students.forEach(s=>sMap[s.id]=s.name);
  const tbody = document.querySelector('#recLogTable tbody');
  const recent = [...records].sort((a,b)=>b.createdAt-a.createdAt).slice(0,15);
  tbody.innerHTML = recent.map(r=>`
    <tr><td>${r.date||formatDate(r.createdAt)}</td><td class="td-name">${sMap[r.studentId]||'-'}</td>
    <td><span class="badge bb">${REC_TYPES[r.type]||r.type}</span></td>
    <td><span style="font-weight:700;color:var(--g2)">${r.hafzScore||10}/10</span></td>
    <td><span style="font-weight:700;color:var(--gold2)">${r.tajweedScore||10}/10</span></td></tr>
  `).join('') || '<tr><td colspan="5"><div class="empty"><p>لا يوجد سجل تسميع</p></div></td></tr>';
}

