# ============================================================
#  deploy/.env.prod.example
#  انسخ هذا الملف إلى .env.prod وعدّل القيم قبل النشر
#
#  cp deploy/.env.prod.example deploy/.env.prod
#  chmod 600 deploy/.env.prod
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=8080
# ENV must be "production" in prod
ENV=production

# ── Docker Image ─────────────────────────────────────────────
# اسم الـ image بعد البناء (docker build -t quran-api:latest .)
API_IMAGE=quran-api:latest

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=quran_school
POSTGRES_USER=quran

# ⚠️  غيّر هذه القيمة لكلمة مرور قوية قبل النشر
# توليد: openssl rand -base64 32 | tr -d /=+ | cut -c1-32
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Migrations ───────────────────────────────────────────────
# false = الافتراضي (لا تشغّل migrations عند الإقلاع)
# true  = شغّل migrations مرة واحدة ثم أعد تعيينها إلى false
RUN_MIGRATIONS=false
MIGRATIONS_DIR=/migrations

# ── JWT Secrets ───────────────────────────────────────────────
# ⚠️  يجب أن يكون كل secret مختلفاً وعشوائياً تماماً
# توليد: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_also_openssl_rand_hex_32

# مدة صلاحية Access Token بالدقائق (15 موصى به)
JWT_ACCESS_TTL_MIN=15
# مدة صلاحية Refresh Token بالأيام (7 موصى به)
JWT_REFRESH_TTL_DAYS=7

# ── Backups ───────────────────────────────────────────────────
# المجلد على الـ host الذي تُحفظ فيه ملفات الـ backup
# يجب أن يكون موجوداً: mkdir -p /opt/quran/backups
BACKUP_DIR=/opt/quran/backups

# ── Domain (للـ Nginx + Certbot) ──────────────────────────────
# مثال: api.yourschool.com
DOMAIN=api.yourdomain.com
